---
import JMeterLayout from "../../layouts/JMeterLayout.astro";

const postImports = import.meta.glob('./**/*.mdx', { eager: true });

const FALLBACK_IMAGE = '/blog/default.svg';

const posts = Object.entries(postImports)
  .filter(([path, post]: [string, any]) => !path.endsWith('index.astro') && post.frontmatter)
  .map(([path, post]: [string, any]) => ({
    slug: path.replace('./', '').replace(/\/index\.mdx$/, '').replace(/\.mdx$/, ''),
    ...post.frontmatter,
  }))
  .filter((post: any) => !post.draft)
  .sort((a: any, b: any) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf());
---

<JMeterLayout hasSlot={true} activeProduct="blog">
  <div class="flex-1 overflow-y-auto p-6 md:p-10">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Blog</h1>
      <p class="text-slate-400 text-lg mb-8">Insights, tutorials, and updates from JMeter.AI</p>

      <div class="space-y-6">
        {posts.map((post: any) => {
          const cardImage = post.image && String(post.image).trim().length > 0 ? post.image : FALLBACK_IMAGE;
          const cardAlt = post.imageAlt ?? post.title;
          return (
            <article class={`group bg-slate-800/50 border rounded-lg overflow-hidden hover:border-cyan-500/50 transition-colors ${post.featured ? 'border-cyan-500/40 ring-1 ring-cyan-500/20' : 'border-slate-700/50'}`}>
              <a href={`/blog/${post.slug}/`} class="block">
                <div class="relative aspect-[2/1] bg-slate-900/40 overflow-hidden">
                  <img
                    src={cardImage}
                    alt={cardAlt}
                    loading="lazy"
                    decoding="async"
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  />
                  {post.featured && (
                    <span class="absolute top-3 left-3 px-2 py-0.5 bg-cyan-500 text-slate-950 rounded text-xs font-semibold tracking-wide uppercase">
                      Featured
                    </span>
                  )}
                </div>
                <div class="p-6">
                  <h2 class="text-xl font-semibold text-white mb-2 group-hover:text-cyan-300 transition-colors">{post.title}</h2>
                  <p class="text-slate-400 mb-3">{post.description}</p>
                  <div class="flex items-center gap-4 text-sm text-slate-500 flex-wrap">
                    <time datetime={new Date(post.pubDate).toISOString()}>
                      {new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    <span>by {post.author ?? 'QAInsights'}</span>
                    {post.tags?.length > 0 && (
                      <div class="flex gap-2">
                        {post.tags.map((tag: string) => (
                          <span class="px-2 py-0.5 bg-cyan-500/10 text-cyan-400 rounded text-xs">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-slate-500">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </div>
</JMeterLayout>
