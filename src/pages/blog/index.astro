---
import JMeterLayout from "../../layouts/JMeterLayout.astro";
import MeshGradient from "../../components/MeshGradient.astro";

const postImports = import.meta.glob('./*.mdx', { eager: true });

const posts = Object.entries(postImports)
  .filter(([path, post]: [string, any]) => !path.endsWith('index.astro') && post.frontmatter)
  .map(([path, post]: [string, any]) => ({
    slug: path.replace('./', '').replace(/\.mdx$/, ''),
    ...post.frontmatter,
  }))
  .filter((post: any) => !post.draft)
  .sort((a: any, b: any) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf());
---

<JMeterLayout hasSlot={true} activeProduct="blog">
  <div class="flex-1 overflow-y-auto p-6 md:p-10">
    <div class="max-w-3xl mx-auto">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">Blog</h1>
      <p class="text-slate-400 text-lg mb-8">Insights, tutorials, and updates from JMeter.AI</p>

      <div class="space-y-8">
        {posts.map((post: any) => {
          const seed = post.title.replace(/\s+/g, '-').toLowerCase();
          const authorName = post.author || 'QAInsights';
          const readTime = post.readTime ?? '5 min read';
          const hasImage = post.image && String(post.image).trim().length > 0;
          return (
            <article class="group">
              <a href={`/blog/${post.slug}/`} class="flex flex-col md:flex-row md:items-center gap-6 md:gap-8">
                <figure class="relative w-full md:w-80 lg:w-96 flex-shrink-0 rounded-xl overflow-hidden border border-slate-700/50 aspect-[16/10]">
                  {post.featured && (
                    <span class="absolute top-3 left-3 z-10 px-2 py-1 bg-lime-400 text-slate-900 text-xs font-bold rounded uppercase tracking-wide">
                      Featured
                    </span>
                  )}
                  {hasImage ? (
                    <img
                      src={post.image}
                      alt={post.imageAlt ?? post.title}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                    />
                  ) : (
                    <MeshGradient seed={seed} class="w-full h-full transition-transform duration-300 group-hover:scale-[1.02]" />
                  )}
                </figure>
                <div class="flex flex-col justify-center flex-1">
                  <div class="flex items-center gap-3 text-xs text-slate-400 uppercase tracking-wider mb-3">
                    <time datetime={new Date(post.pubDate).toISOString()}>
                      {new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    <span class="text-slate-600">•</span>
                    <span>{readTime}</span>
                  </div>
                  <h2 class="text-2xl md:text-3xl font-bold text-white mb-3 group-hover:text-cyan-300 transition-colors leading-tight">{post.title}</h2>
                  <p class="text-base text-slate-400 mb-4">{post.description}</p>
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-lime-400 flex items-center justify-center text-slate-900 font-semibold text-sm">
                      {authorName.charAt(0).toUpperCase()}
                    </div>
                    <span class="text-sm text-slate-300">{authorName}</span>
                  </div>
                </div>
              </a>
            </article>
          );
        })}
      </div>

      {posts.length === 0 && (
        <div class="text-center py-12">
          <p class="text-slate-500">No blog posts yet. Check back soon!</p>
        </div>
      )}
    </div>
  </div>
</JMeterLayout>
