---
import { getCollection, render } from 'astro:content';
import JMeterLayout from "../../layouts/JMeterLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<JMeterLayout 
  title={post.data.title} 
  description={post.data.description}
>
  <article class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-8">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{post.data.title}</h1>
      <p class="text-lg text-slate-400 mb-4">{post.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-slate-500">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>by {post.data.author}</span>
        {post.data.tags.length > 0 && (
          <div class="flex gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-0.5 bg-cyan-500/10 text-cyan-400 rounded text-xs">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>
    
    <div class="prose prose-invert prose-cyan max-w-none">
      <Content />
    </div>
    
    <footer class="mt-12 pt-8 border-t border-slate-800">
      <a href="/blog/" class="text-cyan-400 hover:text-cyan-300 transition-colors">
        ← Back to Blog
      </a>
    </footer>
  </article>
</JMeterLayout>
