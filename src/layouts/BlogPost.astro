---
import JMeterLayout from './JMeterLayout.astro';
import MeshGradient from '../components/MeshGradient.astro';

interface Props {
  title: string;
  description: string;
  pubDate: string | Date;
  author?: string;
  tags?: string[];
  featured?: boolean;
  readTime?: string;
  image?: string;
  imageAlt?: string;
}

const props = Astro.props as Props & { frontmatter?: Props };
const frontmatter: Props = props.frontmatter ?? props;
const {
  title,
  description,
  pubDate,
  author = 'QAInsights',
  tags = [],
  featured = false,
  readTime = '5 min read',
  image,
  imageAlt,
} = frontmatter;
const date = pubDate instanceof Date ? pubDate : new Date(String(pubDate));
const seed = title.replace(/\s+/g, '-').toLowerCase();
const hasImage = image && String(image).trim().length > 0;

const siteUrl = "https://jmeter.ai";
const _rawBlogUrl = new URL(Astro.url?.toString() ?? (siteUrl + "/"));
_rawBlogUrl.search = "";
_rawBlogUrl.hash = "";
const pageUrl = _rawBlogUrl.toString();

const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${pageUrl}#article`,
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  inLanguage: "en-US",
  url: pageUrl,
  author: {
    "@type": "Person",
    name: author,
    url: "https://qainsights.com",
  },
  publisher: {
    "@id": `${siteUrl}/#organization`,
  },
  isPartOf: {
    "@id": `${siteUrl}/#website`,
  },
  keywords: tags.join(", "),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
};
---

<JMeterLayout hasSlot={true} activeProduct="blog">
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingLd)} />
  <div class="flex-1 overflow-y-auto p-6 md:p-10">
    <article class="max-w-3xl mx-auto">
      <header class="mb-8 text-center">
        <div class="flex items-center justify-center gap-3 text-xs text-slate-400 uppercase tracking-wider mb-3">
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="text-slate-600">•</span>
          <span>{author}</span>
          <span class="text-slate-600">•</span>
          <span>{readTime}</span>
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 leading-tight">{title}</h1>
        <p class="text-lg text-slate-400 mb-6 max-w-2xl mx-auto">{description}</p>
        {tags.length > 0 && (
          <div class="flex flex-wrap justify-center gap-2 mb-8">
            {tags.map((tag: string) => (
              <span class="px-3 py-1 bg-slate-700/50 text-slate-300 border border-slate-600/50 rounded-full text-sm font-medium hover:bg-slate-700 transition-colors">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <figure class="mb-8 rounded-xl overflow-hidden border border-slate-700/50 aspect-[16/9]">
        {hasImage ? (
          <img
            src={image}
            alt={imageAlt ?? title}
            loading="eager"
            decoding="async"
            class="w-full h-full object-cover"
          />
        ) : (
          <MeshGradient seed={seed} class="w-full h-full" />
        )}
      </figure>

      <div class="prose prose-invert prose-cyan max-w-none">
        <slot />
      </div>

      <footer class="mt-12 pt-8 border-t border-slate-800">
        <a href="/blog/" class="text-cyan-400 hover:text-cyan-300 transition-colors">
          &larr; Back to Blog
        </a>
      </footer>
    </article>
  </div>
</JMeterLayout>
