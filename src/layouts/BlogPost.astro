---
import JMeterLayout from './JMeterLayout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: string | Date;
  author?: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  featured?: boolean;
}

const FALLBACK_IMAGE = '/blog/default.svg';
const props = Astro.props as Props & { frontmatter?: Props };
const frontmatter: Props = props.frontmatter ?? props;
const {
  title,
  description,
  pubDate,
  author = 'QAInsights',
  tags = [],
  image,
  imageAlt,
} = frontmatter;
const date = pubDate instanceof Date ? pubDate : new Date(String(pubDate));
const heroSrc = image && String(image).trim().length > 0 ? image : FALLBACK_IMAGE;
const heroAlt = imageAlt ?? title;

const siteUrl = "https://jmeter.ai";
const pageUrl = Astro.url?.toString() ?? siteUrl;
const heroAbsUrl = heroSrc.startsWith("http") ? heroSrc : `${siteUrl}${heroSrc}`;

const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${pageUrl}#article`,
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  inLanguage: "en-US",
  url: pageUrl,
  image: {
    "@type": "ImageObject",
    url: heroAbsUrl,
  },
  author: {
    "@type": "Person",
    name: author,
    url: "https://qainsights.com",
  },
  publisher: {
    "@id": `${siteUrl}/#organization`,
  },
  isPartOf: {
    "@id": `${siteUrl}/#website`,
  },
  keywords: tags.join(", "),
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
};
---

<JMeterLayout hasSlot={true} activeProduct="blog">
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingLd)} />
  <div class="flex-1 overflow-y-auto p-6 md:p-10">
    <article class="max-w-3xl mx-auto">
      <figure class="mb-8 rounded-lg overflow-hidden border border-slate-700/50 bg-slate-800/30">
        <img
          src={heroSrc}
          alt={heroAlt}
          loading="eager"
          decoding="async"
          class="w-full h-auto aspect-[2/1] object-cover"
        />
      </figure>
      <header class="mb-8">
        <h1 class="text-3xl md:text-4xl font-bold text-white mb-4">{title}</h1>
        <p class="text-lg text-slate-400 mb-4">{description}</p>
        <div class="flex items-center gap-4 text-sm text-slate-500">
          <time datetime={date.toISOString()}>
            {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>by {author}</span>
          {tags.length > 0 && (
            <div class="flex gap-2">
              {tags.map((tag: string) => (
                <span class="px-2 py-0.5 bg-cyan-500/10 text-cyan-400 rounded text-xs">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="prose prose-invert prose-cyan max-w-none">
        <slot />
      </div>

      <footer class="mt-12 pt-8 border-t border-slate-800">
        <a href="/blog/" class="text-cyan-400 hover:text-cyan-300 transition-colors">
          &larr; Back to Blog
        </a>
      </footer>
    </article>
  </div>
</JMeterLayout>
