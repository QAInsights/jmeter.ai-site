---
import "../styles/global.css";
import SEOHead from "../components/SEOHead.astro";

interface Props {
  hasSlot?: boolean;
  activeProduct?: string;
}

const { hasSlot = false, activeProduct = "feather-wand" } = Astro.props;
import TitleBar from "../components/TitleBar.astro";
import MenuBar from "../components/MenuBar.astro";
import Toolbar from "../components/Toolbar.astro";
import TabBar from "../components/TabBar.astro";
import TreeView from "../components/TreeView.astro";
import DetailPanel from "../components/DetailPanel.astro";
import StatusBar from "../components/StatusBar.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead />
  </head>
  <body class="flex flex-col h-screen md:h-screen md:overflow-hidden overflow-auto min-h-screen bg-jm-bg" data-active-product={activeProduct}>
    <!-- SVG Sprite Sheet: referenced via <use href="#icon-*"> everywhere -->
    <svg xmlns="http://www.w3.org/2000/svg" style="display:none" aria-hidden="true">
      <symbol id="icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></symbol>
      <symbol id="icon-info" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></symbol>
      <symbol id="icon-zap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/></symbol>
      <symbol id="icon-git-compare" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M11 18H8a2 2 0 0 1-2-2V9"/></symbol>
      <symbol id="icon-download" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></symbol>
      <symbol id="icon-github" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></symbol>
      <symbol id="icon-users" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></symbol>
      <symbol id="icon-calculator" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/><path d="M12 7V3"/><path d="M12 21v-4"/><path d="m3.5 9 3.5-2"/><path d="m17 13 3.5 2"/><path d="M3.5 15l3.5-2"/><path d="M17 11l3.5 2"/></symbol>
      <symbol id="icon-play-circle" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></symbol>
      <symbol id="icon-wand-sparkles" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/></symbol>
      <symbol id="icon-keyboard" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 8h.01"/><path d="M12 12h.01"/><path d="M14 8h.01"/><path d="M16 12h.01"/><path d="M18 8h.01"/><path d="M6 8h.01"/><path d="M7 16h10"/><path d="M8 12h.01"/><rect width="20" height="16" x="2" y="4" rx="2"/></symbol>
      <symbol id="icon-palette" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/></symbol>
      <symbol id="icon-app-window" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="M10 4v4"/><path d="M2 8h20"/><path d="M6 4v4"/></symbol>
      <symbol id="icon-graduation-cap" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></symbol>
      <symbol id="icon-book-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></symbol>
      <symbol id="icon-file-plus" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 15h6"/><path d="M12 18v-6"/></symbol>
      <symbol id="icon-folder-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/></symbol>
      <symbol id="icon-save" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></symbol>
      <symbol id="icon-play" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="6 3 20 12 6 21 6 3"/></symbol>
      <symbol id="icon-square" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/></symbol>
      <symbol id="icon-search" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></symbol>
      <symbol id="icon-zoom-in" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6"/><path d="M8 11h6"/></symbol>
      <symbol id="icon-zoom-out" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/></symbol>
      <symbol id="icon-external-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></symbol>
      <symbol id="icon-warning" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></symbol>
      <symbol id="icon-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></symbol>
      <symbol id="icon-x" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></symbol>
      <symbol id="icon-scissors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/></symbol>
      <symbol id="icon-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></symbol>
      <symbol id="icon-clipboard-paste" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H9a1 1 0 0 0-1 1v2c0 .6.4 1 1 1h6c.6 0 1-.4 1-1V3c0-.6-.4-1-1-1Z"/><path d="M8 4H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2M16 4h2a2 2 0 0 1 2 2v2"/><path d="M21 14H11"/><path d="m15 10-4 4 4 4"/></symbol>
      <symbol id="icon-rotate-ccw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></symbol>
      <symbol id="icon-toggle-left" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="12" x="2" y="6" rx="6" ry="6"/><circle cx="8" cy="12" r="2"/></symbol>
      <symbol id="icon-eraser" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21"/><path d="M22 21H7"/><path d="m5 11 9 9"/></symbol>
      <symbol id="icon-refresh-cw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/><path d="M20 4v6h-6"/><path d="M20.49 15a9 9 1 1 1-2.12-9.36L23 10"/></symbol>
      <symbol id="icon-zoom-reset" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 11a5 5 0 1 0 0 10 5 5 0 0 0 0-10z"/><path d="m21 21-4.35-4.35"/><path d="M11 8V2"/><path d="M2 11h6"/><path d="M11 14v6"/><path d="M14 11h6"/></symbol>
    </svg>
    <!-- JMeter Chrome -->
    <TitleBar />
    <!-- Mobile sidebar toggle button -->
    <button
      id="mobile-sidebar-toggle"
      class="md:hidden fixed bottom-4 left-4 z-50 w-10 h-10 rounded-full bg-jm-accent text-jm-bg flex items-center justify-center shadow-lg"
      aria-label="Toggle navigation"
      title="Toggle sidebar"
    >
      <svg id="sidebar-menu-icon" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/>
      </svg>
      <svg id="sidebar-close-icon" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
      </svg>
    </button>
    <MenuBar />
    <Toolbar />
    <TabBar />

    <!-- Main Content: Tree + Detail Split Pane -->
    <div class="flex flex-1 min-h-0 relative">
      <!-- Mobile sidebar overlay backdrop -->
      <div id="sidebar-backdrop" class="hidden fixed inset-0 bg-black/50 z-40 md:hidden" aria-hidden="true"></div>
      <TreeView />
      <div class="jm-resizer" id="resizer" role="separator" aria-label="Resize panels"></div>
      {hasSlot ? <slot /> : <DetailPanel />}
    </div>

    <!-- Status Bar -->
    <StatusBar />

    <!-- Super Key Command Palette Overlay (injected by JS) -->
    <div id="sk-palette-root"></div>

    <!-- Interactivity Script -->
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        // --- Mobile Sidebar Drawer ---
        const sidebarToggleBtn = document.getElementById("mobile-sidebar-toggle");
        const sidebarBackdrop = document.getElementById("sidebar-backdrop");
        const menuIcon = document.getElementById("sidebar-menu-icon");
        const closeIcon = document.getElementById("sidebar-close-icon");
        const treePanelEl = document.getElementById("tree-panel");
        let sidebarOpen = false;

        function isMobile() { return window.innerWidth < 768; }

        function initSidebarForSize() {
          if (!treePanelEl) return;
          if (isMobile()) {
            treePanelEl.style.width = "0px"; treePanelEl.style.minWidth = "0";
            treePanelEl.style.overflow = "hidden"; treePanelEl.style.position = "absolute";
            treePanelEl.style.top = "0"; treePanelEl.style.left = "0";
            treePanelEl.style.bottom = "0"; treePanelEl.style.zIndex = "45";
            treePanelEl.style.maxWidth = "280px"; sidebarOpen = false;
          } else {
            treePanelEl.style.width = "256px"; treePanelEl.style.minWidth = "";
            treePanelEl.style.overflow = ""; treePanelEl.style.position = "";
            treePanelEl.style.top = ""; treePanelEl.style.left = "";
            treePanelEl.style.bottom = ""; treePanelEl.style.zIndex = "";
            treePanelEl.style.maxWidth = ""; sidebarBackdrop?.classList.add("hidden");
          }
        }

        function openSidebar() {
          if (!treePanelEl || !isMobile()) return;
          sidebarOpen = true; treePanelEl.style.width = "260px"; treePanelEl.style.overflow = "";
          sidebarBackdrop?.classList.remove("hidden"); menuIcon?.classList.add("hidden"); closeIcon?.classList.remove("hidden");
        }

        function closeSidebar() {
          if (!treePanelEl) return;
          sidebarOpen = false; treePanelEl.style.width = "0px"; treePanelEl.style.overflow = "hidden";
          sidebarBackdrop?.classList.add("hidden"); menuIcon?.classList.remove("hidden"); closeIcon?.classList.add("hidden");
        }

        sidebarToggleBtn?.addEventListener("click", () => { if (sidebarOpen) closeSidebar(); else openSidebar(); });
        sidebarBackdrop?.addEventListener("click", closeSidebar);
        document.querySelectorAll("[data-node]").forEach((node) => {
          node.addEventListener("click", () => { if (isMobile() && sidebarOpen) closeSidebar(); });
        });
        window.addEventListener("resize", initSidebarForSize);
        initSidebarForSize();

        // --- State ---
        let activeTab = "feather-wand";
        let activeNodes: Record<string, string> = {
          "feather-wand": "overview", "super-key": "overview", "jmeter-studio": "overview",
          "prism": "overview", "perftractor": "overview", "academy": "playlist",
          "k6": "k6", "performance-engineering": "performance-engineering", "regex": "regex",
          "locust": "locust", "loadrunner": "loadrunner", "devtools": "devtools",
          "gatling": "gatling", "statistics": "statistics", "chaos": "chaos", "vault": "vault",
          "prompts": "prompts", "blog": "blog",
        };

        // --- Tab Switching ---
        const tabBar = document.getElementById("tab-bar");
        const tabs = tabBar?.querySelectorAll<HTMLButtonElement>("[data-tab]") ?? [];
        const treePanels = document.querySelectorAll<HTMLElement>("[data-tree-product]");
        const detailPanels = document.querySelectorAll<HTMLElement>("[data-panels-product]");

        function switchTab(tabId: string) {
          activeTab = tabId;
          tabs.forEach((tab) => {
            const isActive = tab.dataset.tab === tabId;
            const color = tab.dataset.color || "#00e5ff";
            tab.setAttribute("aria-selected", isActive ? "true" : "false");
            if (isActive) {
              tab.className = tab.className
                .replace(/bg-transparent/g, "bg-jm-tab-active")
                .replace(/border-transparent/g, "border-jm-border")
                .replace(/text-jm-text-muted/g, "text-jm-text")
                .replace(/hover:text-jm-text-dim/g, "")
                .replace(/hover:bg-jm-tab-hover/g, "");
              if (!tab.className.includes("bg-jm-tab-active"))
                tab.classList.add("bg-jm-tab-active", "border-jm-border", "text-jm-text");
              const icon = tab.querySelector("svg");
              if (icon) icon.style.color = color;
              let indicator = tab.querySelector("#tab-indicator") as HTMLElement;
              if (!indicator) {
                indicator = document.createElement("div");
                indicator.id = "tab-indicator";
                indicator.className = "absolute bottom-0 left-0 right-0 h-0.5 rounded-full";
                tab.appendChild(indicator);
              }
              indicator.style.background = color;
            } else {
              tab.className = tab.className
                .replace(/bg-jm-tab-active/g, "bg-transparent")
                .replace(/border-jm-border(?!\S)/g, "border-transparent")
                .replace(/text-jm-text(?!-)/g, "text-jm-text-muted");
              const icon = tab.querySelector("svg");
              if (icon) icon.style.color = "";
              const indicator = tab.querySelector("#tab-indicator");
              if (indicator) indicator.remove();
            }
          });
          treePanels.forEach((panel) => { panel.classList.toggle("hidden", panel.dataset.treeProduct !== tabId); });
          detailPanels.forEach((panel) => { panel.classList.toggle("hidden", panel.dataset.panelsProduct !== tabId); });
          const currentNode = activeNodes[tabId] || "overview";
          highlightTreeNode(tabId, currentNode);
          showDetailContent(tabId, currentNode);
        }

        // On slot pages (e.g. blog article), the DetailPanel isn't rendered,
        // so tab clicks must navigate to the appropriate page instead of
        // just toggling local state.
        const isSlotPage = document.querySelector("main#detail-panel") === null;

        tabs.forEach((tab) => {
          tab.addEventListener("click", (e) => {
            const target = e.target as HTMLElement;
            if (target.closest(".tab-close")) return;
            const tabId = tab.dataset.tab;
            if (!tabId) return;
            if (isSlotPage) {
              window.location.href = tabId === "blog" ? "/blog/" : `/#${tabId}`;
              return;
            }
            switchTab(tabId);
          });
        });

        // --- Initial active tab ---
        // Priority: URL hash (e.g. /#super-key) > server-provided activeProduct.
        const hashProduct = window.location.hash.replace(/^#/, "");
        const initialProduct = hashProduct || document.body.dataset.activeProduct;
        if (initialProduct && initialProduct !== "feather-wand") {
          const tabExists = Array.from(tabs).some((t) => t.dataset.tab === initialProduct);
          if (tabExists) switchTab(initialProduct);
        }

        // --- Tree Node Selection ---
        const treeNodes = document.querySelectorAll<HTMLButtonElement>("[data-node]");

        function highlightTreeNode(productId: string, nodeId: string) {
          const product = document.querySelector(`[data-tree-product="${productId}"]`);
          if (!product) return;
          const nodes = product.querySelectorAll<HTMLButtonElement>("[data-node]");
          const color = (document.querySelector(`[data-tab="${productId}"]`) as HTMLElement)?.dataset.color || "#00e5ff";
          nodes.forEach((node) => {
            const isActive = node.dataset.node === nodeId;
            node.setAttribute("aria-selected", isActive ? "true" : "false");
            node.classList.remove("bg-jm-tree-active/60", "text-jm-text", "text-jm-text-dim");
            if (isActive) {
              node.style.background = `color-mix(in srgb, ${color} 15%, transparent)`;
              node.classList.add("text-jm-text");
              let ind = node.querySelector(".active-ind") as HTMLElement;
              if (!ind) {
                ind = document.createElement("span");
                ind.className = "active-ind absolute left-0 top-0 bottom-0 w-[2px] rounded-r";
                node.appendChild(ind);
              }
              ind.style.background = color;
            } else {
              node.style.background = "";
              node.classList.add("text-jm-text-dim");
              node.querySelector(".active-ind")?.remove();
            }
          });
        }

        function showDetailContent(productId: string, nodeId: string) {
          const container = document.querySelector(`[data-panels-product="${productId}"]`);
          if (!container) return;
          container.querySelectorAll<HTMLElement>("[data-detail]").forEach((content) => {
            const isActive = content.dataset.detail === `${productId}-${nodeId}`;
            content.classList.toggle("hidden", !isActive);
            if (isActive) content.classList.add("panel-enter");
          });
          const sectionEl = container.querySelector(`[data-panel-section="${productId}"]`);
          if (sectionEl) {
            const nodeLabel = document.querySelector(`[data-tree-product="${productId}"] [data-node="${nodeId}"]`)?.textContent?.trim();
            sectionEl.textContent = nodeLabel || "Overview";
          }
        }

        treeNodes.forEach((node) => {
          node.addEventListener("click", () => {
            const nodeId = node.dataset.node;
            const productId = node.dataset.product;
            if (!nodeId || !productId) return;
            // Navigate to external URL if data-href is set (e.g. Blog)
            const href = node.dataset.href;
            if (href) { window.location.href = href; return; }
            activeNodes[productId] = nodeId;
            highlightTreeNode(productId, nodeId);
            showDetailContent(productId, nodeId);
          });
        });

        // --- Resizable Split Pane ---
        const resizer = document.getElementById("resizer");
        const treePanel = document.getElementById("tree-panel");
        if (resizer && treePanel) {
          let isResizing = false;
          resizer.addEventListener("mousedown", (e) => { isResizing = true; document.body.style.cursor = "col-resize"; document.body.style.userSelect = "none"; e.preventDefault(); });
          document.addEventListener("mousemove", (e) => { if (!isResizing) return; treePanel.style.width = `${Math.max(160, Math.min(500, e.clientX))}px`; });
          document.addEventListener("mouseup", () => { if (isResizing) { isResizing = false; document.body.style.cursor = ""; document.body.style.userSelect = ""; } });
        }

        // --- Live Theme Switcher ---
        const CSS_VAR_MAP: Record<string, string> = {
          bg: "--color-jm-bg", surface: "--color-jm-surface", surfaceAlt: "--color-jm-surface-alt",
          border: "--color-jm-border", borderLight: "--color-jm-border-light",
          text: "--color-jm-text", textDim: "--color-jm-text-dim", textMuted: "--color-jm-text-muted",
          titleBar: "--color-jm-title-bar", menuBg: "--color-jm-menu-bg", toolbarBg: "--color-jm-toolbar-bg",
          tabActive: "--color-jm-tab-active", tabHover: "--color-jm-tab-hover",
          treeHover: "--color-jm-tree-hover", treeActive: "--color-jm-tree-active",
          accent: "--color-jm-accent", accentDim: "--color-jm-accent-dim",
          cyan: "--color-jm-cyan", amber: "--color-jm-amber", purple: "--color-jm-purple",
          green: "--color-jm-green", red: "--color-jm-red", statusBg: "--color-jm-status-bg",
        };

        function applyTheme(themeId: string, colors: Record<string, string>) {
          const root = document.documentElement;
          root.classList.add("theme-transitioning");
          for (const [key, cssVar] of Object.entries(CSS_VAR_MAP)) { if (colors[key]) root.style.setProperty(cssVar, colors[key]); }
          document.querySelectorAll<HTMLElement>(".theme-swatch").forEach((btn) => {
            const ring = btn.querySelector<HTMLElement>(".theme-active-ring");
            if (!ring) return;
            if (btn.dataset.themeId === themeId) {
              const c = JSON.parse(btn.dataset.themeColors || "{}");
              ring.style.borderColor = c.accent || "#00e5ff"; ring.style.boxShadow = `0 0 12px ${c.accent || "#00e5ff"}40`;
            } else { ring.style.borderColor = "transparent"; ring.style.boxShadow = "none"; }
          });
          const label = document.getElementById("theme-active-label");
          if (label) {
            const btn = document.querySelector<HTMLElement>(`[data-theme-id="${themeId}"]`);
            label.textContent = `Active: ${btn?.querySelector("[style*='Orbitron']")?.textContent || themeId}`;
            label.style.color = colors.accent || "";
          }
          const glowStyle = document.getElementById("dynamic-glow");
          if (glowStyle) { glowStyle.textContent = `.glow-text-cyan { text-shadow: 0 0 8px ${colors.accent || "#00e5ff"}66; }`; }
          else { const s = document.createElement("style"); s.id = "dynamic-glow"; s.textContent = `.glow-text-cyan { text-shadow: 0 0 8px ${colors.accent || "#00e5ff"}66; }`; document.head.appendChild(s); }
          setTimeout(() => root.classList.remove("theme-transitioning"), 400);
        }

        document.querySelectorAll<HTMLElement>(".theme-swatch").forEach((btn) => {
          btn.addEventListener("click", () => {
            const themeId = btn.dataset.themeId; const colors = JSON.parse(btn.dataset.themeColors || "{}");
            if (themeId) applyTheme(themeId, colors);
          });
        });
        document.getElementById("theme-reset")?.addEventListener("click", () => {
          const defaultBtn = document.querySelector<HTMLElement>('[data-theme-id="default"]');
          if (defaultBtn) applyTheme("default", JSON.parse(defaultBtn.dataset.themeColors || "{}"));
        });
        const defaultRing = document.querySelector<HTMLElement>('[data-theme-id="default"] .theme-active-ring');
        if (defaultRing) { defaultRing.style.borderColor = "#00e5ff"; defaultRing.style.boxShadow = "0 0 12px #00e5ff40"; }

        // --- Super Key Command Palette ---
        const skPaletteRoot = document.getElementById("sk-palette-root");
        const skTree = document.getElementById("sk-tree");
        const skResults = document.getElementById("sk-results");
        const skStatusText = document.getElementById("sk-status-text");
        const skStatusIndicator = document.getElementById("sk-status-indicator");
        const skProgress = document.getElementById("sk-progress");
        const skResetBtn = document.getElementById("sk-reset-btn");
        let skElementCatalog: Array<{name: string; type: string; category: string; icon: string; parent?: string}> = [];
        const skDataEl = document.getElementById("jmeter-elements-data");
        if (skDataEl) { try { skElementCatalog = JSON.parse(skDataEl.dataset.elements || "[]"); } catch(e) {} }
        interface SkTreeNode { name: string; icon: string; depth: number; children: SkTreeNode[]; }
        let skTestPlan: SkTreeNode = { name: "Test Plan", icon: "📋", depth: 0, children: [] };
        let skPaletteOpen = false, skActiveIndex = 0, skRunning = false;
        let skRunInterval: number | null = null, skSampleCount = 0;

        function skFindParent(node: SkTreeNode, parentName: string): SkTreeNode | null {
          if (node.name === parentName || node.name.includes(parentName)) return node;
          for (const child of node.children) { const found = skFindParent(child, parentName); if (found) return found; }
          return null;
        }
        function skRenderTree() {
          if (!skTree) return; skTree.innerHTML = "";
          function renderNode(node: SkTreeNode, depth: number) {
            const div = document.createElement("div");
            div.className = `sk-tree-node flex items-center gap-1.5 py-1 rounded text-xs ${depth === 0 ? "" : "sk-tree-node-new"}`;
            div.style.paddingLeft = `${8 + depth * 16}px`; div.style.paddingRight = "8px";
            div.dataset.skNode = node.name; div.dataset.skDepth = String(depth);
            div.innerHTML = `<span class="text-sm">${node.icon}</span><span class="text-jm-text" style="font-family: 'JetBrains Mono', monospace;">${node.name}</span>`;
            skTree.appendChild(div);
            for (const child of node.children) renderNode(child, depth + 1);
          }
          renderNode(skTestPlan, 0);
        }
        function skLogMessage(msg: string, level: string) {
          if (!skResults) return;
          skResults.querySelector(".flex.flex-col.items-center")?.remove();
          const now = new Date();
          const timeStr = `${String(now.getHours()).padStart(2,"0")}:${String(now.getMinutes()).padStart(2,"0")}:${String(now.getSeconds()).padStart(2,"0")}`;
          const entry = document.createElement("div"); entry.className = "sk-log-entry";
          const dotClass = level === "pass" ? "sk-log-pass" : level === "fail" ? "sk-log-fail" : level === "warn" ? "sk-log-warn" : "sk-log-pass";
          entry.innerHTML = `<span class="sk-log-time">${timeStr}</span><span class="sk-log-status ${dotClass}"></span><span class="text-jm-text-dim">${msg}</span>`;
          skResults.appendChild(entry); skResults.scrollTop = skResults.scrollHeight;
        }
        function skSetStatus(text: string, color: string, pulse: boolean) {
          if (skStatusText) { skStatusText.textContent = text; skStatusText.style.color = color; }
          if (skStatusIndicator) {
            const dot = skStatusIndicator.querySelector("span:first-child") as HTMLElement;
            if (dot) { dot.style.background = color; dot.className = `w-2 h-2 rounded-full ${pulse ? "sk-running-dot" : ""}`; }
          }
        }
        function skAddElement(element: {name: string; type: string; category: string; icon: string; parent?: string}) {
          if (element.type === "action") { skHandleAction(element.name); return; }
          let parent = skFindParent(skTestPlan, element.parent || "Test Plan") || skTestPlan;
          if (!parent.children.some(c => c.name === element.name))
            parent.children.push({ name: element.name, icon: element.icon, depth: parent.depth + 1, children: [] });
          skRenderTree(); skLogMessage(`Added: ${element.icon} ${element.name}`, "info");
        }
        function skHandleAction(actionName: string) {
          if (actionName.includes("Run")) skStartRun();
          else if (actionName.includes("Stop")) skStopRun();
          else if (actionName.includes("Thread Dump")) skLogMessage("Thread dump captured", "warn");
          else if (actionName.includes("Save")) skLogMessage("Test plan saved", "info");
        }
        function skStartRun() {
          const hasSampler = skTestPlan.children.some(tg => tg.children.some(c => c.name.includes("Request") || c.name.includes("Sampler")));
          if (!hasSampler) { skLogMessage("⚠️ No sampler found. Add HTTP Request first.", "warn"); return; }
          if (skRunning) return;
          skRunning = true; skSampleCount = 0; skSetStatus("Running", "#00e676", true); skLogMessage("▶️ Test started", "info");
          const samplerNames: string[] = [];
          function findSamplers(node: SkTreeNode) { if (node.name.includes("Request") || node.name.includes("Sampler")) samplerNames.push(node.name); node.children.forEach(findSamplers); }
          findSamplers(skTestPlan);
          skRunInterval = window.setInterval(() => {
            if (!skRunning) return; skSampleCount++;
            const sampler = samplerNames[Math.floor(Math.random() * samplerNames.length)];
            const responseTime = Math.floor(Math.random() * 450) + 50;
            const statusCode = Math.random() > 0.12 ? 200 : (Math.random() > 0.5 ? 500 : 404);
            const pass = statusCode === 200;
            skLogMessage(`#${skSampleCount} ${sampler} → ${statusCode} (${responseTime}ms)`, pass ? "pass" : "fail");
            if (skProgress) { skProgress.style.width = `${Math.min(100, (skSampleCount / 50) * 100)}%`; skProgress.style.background = pass ? "" : "var(--color-jm-red)"; }
          }, 600);
        }
        function skStopRun() {
          if (!skRunning) return; skRunning = false;
          if (skRunInterval !== null) { clearInterval(skRunInterval); skRunInterval = null; }
          skSetStatus("Stopped", "#ff5252", false); skLogMessage(`⏹️ Test stopped — ${skSampleCount} samples`, "warn");
          if (skProgress) skProgress.style.width = "100%";
        }
        function skOpenPalette() {
          if (skPaletteOpen || !skPaletteRoot) return;
          skPaletteOpen = true; skActiveIndex = 0;
          skPaletteRoot.innerHTML = `<div class="sk-palette-overlay" id="sk-overlay"><div class="sk-palette"><div class="sk-palette-input-row"><div class="sk-palette-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg></div><input type="text" class="sk-palette-input" id="sk-input" placeholder="Need a sampler? An assertion? Just type." autofocus /><div class="sk-palette-count" id="sk-count"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg><span id="sk-count-num">${skElementCatalog.length}</span></div></div><div class="sk-palette-results" id="sk-palette-list"></div></div></div>`;
          const input = document.getElementById("sk-input") as HTMLInputElement;
          const list = document.getElementById("sk-palette-list")!;
          const overlay = document.getElementById("sk-overlay")!;
          skRenderPaletteResults(list, ""); input.focus();
          input.addEventListener("input", () => { skActiveIndex = 0; skRenderPaletteResults(list, input.value); });
          input.addEventListener("keydown", (e) => {
            const items = list.querySelectorAll(".sk-palette-item");
            if (e.key === "ArrowDown") { e.preventDefault(); skActiveIndex = Math.min(skActiveIndex + 1, items.length - 1); skHighlightPaletteItem(list); }
            else if (e.key === "ArrowUp") { e.preventDefault(); skActiveIndex = Math.max(skActiveIndex - 1, 0); skHighlightPaletteItem(list); }
            else if (e.key === "Enter") { e.preventDefault(); const active = items[skActiveIndex] as HTMLElement; if (active) { const filtered = skGetFilteredElements(input.value); if (filtered[parseInt(active.dataset.skIdx || "0")]) { skAddElement(filtered[parseInt(active.dataset.skIdx || "0")]); skClosePalette(); } } }
            else if (e.key === "Escape") skClosePalette();
          });
          overlay.addEventListener("click", (e) => { if (e.target === overlay) skClosePalette(); });
        }
        function skClosePalette() { skPaletteOpen = false; if (skPaletteRoot) skPaletteRoot.innerHTML = ""; }
        function skGetFilteredElements(query: string) {
          const q = query.toLowerCase().trim();
          return q ? skElementCatalog.filter(el => el.name.toLowerCase().includes(q) || el.category.toLowerCase().includes(q)) : skElementCatalog;
        }
        function skRenderPaletteResults(container: HTMLElement, query: string) {
          const filtered = skGetFilteredElements(query); container.innerHTML = "";
          const countEl = document.getElementById("sk-count-num"); if (countEl) countEl.textContent = String(filtered.length);
          filtered.forEach((el, i) => {
            const div = document.createElement("div");
            div.className = `sk-palette-item ${i === skActiveIndex ? "sk-active" : ""}`;
            div.dataset.skIdx = String(i);
            div.innerHTML = `<span class="mr-2">${el.icon}</span><span>${el.name}</span><span class="sk-palette-item-category">${el.category}</span>`;
            div.addEventListener("click", () => { skAddElement(el); skClosePalette(); });
            div.addEventListener("mouseenter", () => { skActiveIndex = i; skHighlightPaletteItem(container); });
            container.appendChild(div);
          });
        }
        function skHighlightPaletteItem(container: HTMLElement) {
          const items = container.querySelectorAll(".sk-palette-item");
          items.forEach((item, i) => item.classList.toggle("sk-active", i === skActiveIndex));
          (items[skActiveIndex] as HTMLElement)?.scrollIntoView({ block: "nearest" });
        }
        skResetBtn?.addEventListener("click", () => {
          skStopRun(); skTestPlan = { name: "Test Plan", icon: "📋", depth: 0, children: [] }; skSampleCount = 0; skRenderTree();
          if (skResults) skResults.innerHTML = `<div class="flex flex-col items-center justify-center h-full text-center opacity-60"><span class="text-3xl mb-2">⌨️</span><p class="text-xs text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">Press Ctrl+K to start</p><p class="text-[10px] text-jm-text-muted mt-1" style="font-family: 'JetBrains Mono', monospace;">Add elements, then "Run" to simulate</p></div>`;
          if (skProgress) skProgress.style.width = "0%"; skSetStatus("Idle", "", false); if (skStatusText) skStatusText.style.color = "";
        });
        skRenderTree();
        document.getElementById("sk-open-palette-btn")?.addEventListener("click", () => skOpenPalette());

        // --- Feather Wand AI Chat ---
        const fwChatInput = document.getElementById("fw-chat-input") as HTMLInputElement;
        const fwChatSend = document.getElementById("fw-chat-send");
        const fwChatMessages = document.getElementById("fw-chat-messages");
        const fwTreeContent = document.getElementById("fw-tree-content");
        const fwElementCount = document.getElementById("fw-element-count");
        let fwElementsAdded = 0;
        let fwHasThreadGroup = false;
        const fwResponses: Record<string, {message: string; element: {name: string; icon: string; parent: string}}> = {
          "thread group": { message: "I'll create a Thread Group with 100 users, 1 second ramp-up, and 5 second loop.", element: { name: "Thread Group", icon: "⚙️", parent: "Test Plan" } },
          "http request": { message: "Adding an HTTP Request sampler with default configuration.", element: { name: "HTTP Request", icon: "📋", parent: "Thread Group" } },
          "assertion": { message: "Adding Response Assertion to validate the response.", element: { name: "Response Assertion", icon: "📋", parent: "HTTP Request" } },
          "timer": { message: "Adding Constant Timer to add 1000ms think time between requests.", element: { name: "Constant Timer", icon: "⏱️", parent: "HTTP Request" } },
          "listener": { message: "Adding View Results Tree listener to see response data.", element: { name: "View Results Tree", icon: "📊", parent: "Thread Group" } },
        };
        function fwAddMessage(content: string, isUser = false, stream = false) {
          if (!fwChatMessages) return;
          const div = document.createElement("div"); div.className = "flex gap-3";
          if (isUser) {
            div.innerHTML = `<div class="w-10 h-10 rounded-lg bg-jm-accent/20 border border-jm-accent/40 flex items-center justify-center shrink-0"><span class="text-base">👤</span></div><div class="flex-1"><div class="text-xs text-jm-text-muted mb-1.5" style="font-family: 'JetBrains Mono', monospace;">You</div><div class="bg-jm-surface border border-jm-border rounded-lg px-4 py-3 text-sm text-jm-text" style="font-family: 'JetBrains Mono', monospace;">${content}</div></div>`;
            fwChatMessages.appendChild(div); fwChatMessages.scrollTop = fwChatMessages.scrollHeight;
          } else {
            div.innerHTML = `<div class="w-10 h-10 rounded-lg bg-[#E87040]/20 border border-[#E87040]/40 flex items-center justify-center shrink-0"><span class="text-base">🪄</span></div><div class="flex-1"><div class="text-xs text-jm-text-muted mb-1.5" style="font-family: 'JetBrains Mono', monospace;">Feather Wand AI</div><div class="bg-jm-surface-alt border border-jm-border rounded-lg px-4 py-3 text-sm text-jm-text-dim" style="font-family: 'JetBrains Mono', monospace;"><span class="fw-streaming-text"></span></div></div>`;
            fwChatMessages.appendChild(div); fwChatMessages.scrollTop = fwChatMessages.scrollHeight;
            if (stream) {
              const textSpan = div.querySelector(".fw-streaming-text") as HTMLElement;
              let i = 0;
              const chars = content.split("");
              const interval = window.setInterval(() => {
                if (i < chars.length) { textSpan.textContent += chars[i]; i++; fwChatMessages.scrollTop = fwChatMessages.scrollHeight; }
                else { clearInterval(interval); }
              }, 15);
            } else {
              const textSpan = div.querySelector(".fw-streaming-text") as HTMLElement;
              if (textSpan) textSpan.textContent = content;
            }
          }
        }
        function fwAddElementToTree(element: {name: string; icon: string; parent: string}) {
          if (!fwTreeContent) return;
          // Remove empty placeholder if present
          const emptyPlaceholder = fwTreeContent.querySelector(".text-jm-text-muted\\/50");
          if (emptyPlaceholder) emptyPlaceholder.remove();
          fwElementsAdded++; if (fwElementCount) fwElementCount.textContent = `${fwElementsAdded} elements`;
          
          let container = fwTreeContent;
          let paddingLeft = "16px";
          
          // If parent is Thread Group, find or create Thread Group container
          if (element.parent === "Thread Group") {
            let tgContainer = fwTreeContent.querySelector(".fw-thread-group-children") as HTMLElement;
            if (!tgContainer) {
              // Create Thread Group node first
              const tgDiv = document.createElement("div");
              tgDiv.className = "fw-tree-node-new";
              tgDiv.innerHTML = `<div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer" style="padding-left: 16px;"><svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg><span class="text-sm">⚙️</span><span class="text-jm-text">Thread Group</span></div><div class="fw-thread-group-children ml-4"></div>`;
              fwTreeContent.appendChild(tgDiv);
              tgContainer = tgDiv.querySelector(".fw-thread-group-children") as HTMLElement;
              setTimeout(() => tgDiv.classList.remove("fw-tree-node-new"), 500);
            }
            container = tgContainer;
            paddingLeft = "16px";
          }
          
          const div = document.createElement("div");
          div.className = "flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded fw-tree-node-new";
          div.style.paddingLeft = paddingLeft;
          div.innerHTML = `<span class="text-sm">${element.icon}</span><span class="text-jm-text">${element.name}</span>`;
          container.appendChild(div); setTimeout(() => div.classList.remove("fw-tree-node-new"), 500);
        }
        function fwSendMessage() {
          if (!fwChatInput) return;
          const message = fwChatInput.value.trim(); if (!message) return;
          fwAddMessage(message, true); fwChatInput.value = "";
          setTimeout(() => {
            const lowerInput = message.toLowerCase();
            // Check for Thread Group first
            if (lowerInput.includes("thread group")) {
              const response = fwResponses["thread group"];
              fwAddMessage(response.message, false, true);
              setTimeout(() => { 
                // Create Thread Group as container node
                if (fwTreeContent) {
                  const emptyPlaceholder = fwTreeContent.querySelector(".text-jm-text-muted\\/50");
                  if (emptyPlaceholder) emptyPlaceholder.remove();
                  let tgContainer = fwTreeContent.querySelector(".fw-thread-group-children") as HTMLElement;
                  if (!tgContainer) {
                    const tgDiv = document.createElement("div");
                    tgDiv.className = "fw-tree-node-new";
                    tgDiv.innerHTML = `<div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer" style="padding-left: 16px;"><svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg><span class="text-sm">⚙️</span><span class="text-jm-text">Thread Group</span></div><div class="fw-thread-group-children ml-4"></div>`;
                    fwTreeContent.appendChild(tgDiv);
                    tgContainer = tgDiv.querySelector(".fw-thread-group-children") as HTMLElement;
                    setTimeout(() => tgDiv.classList.remove("fw-tree-node-new"), 500);
                  }
                  fwElementsAdded++; 
                  if (fwElementCount) fwElementCount.textContent = `${fwElementsAdded} elements`;
                }
                fwHasThreadGroup = true; 
              }, 800);
              return;
            }
            // Validate Thread Group exists for other elements
            if (!fwHasThreadGroup) {
              fwAddMessage("Please add a Thread Group first before adding other elements. Thread Group is the main container for your test plan.", false, true);
              return;
            }
            for (const [key, response] of Object.entries(fwResponses)) {
              if (lowerInput.includes(key)) { fwAddMessage(response.message, false, true); setTimeout(() => fwAddElementToTree(response.element), 800); return; }
            }
            const defaults = ["I can help you create Thread Groups, HTTP Requests, Assertions, Timers, and Listeners. Try asking for one of these!", "Would you like me to add a Thread Group to get started with your test plan?", "I can add various JMeter test elements. What specific element would you like to create?", "Let me help you build a complete test plan. Would you like to start with a Thread Group?"];
            fwAddMessage(defaults[Math.floor(Math.random() * defaults.length)], false, true);
          }, 600);
        }
        fwChatSend?.addEventListener("click", fwSendMessage);
        fwChatInput?.addEventListener("keypress", (e) => { if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); fwSendMessage(); } });
        document.querySelectorAll("[data-fw-suggestion]").forEach(btn => {
          btn.addEventListener("click", () => { const s = btn.getAttribute("data-fw-suggestion"); if (s && fwChatInput) { fwChatInput.value = s; fwChatInput.focus(); } });
        });
        document.getElementById("fw-clear-chat")?.addEventListener("click", () => {
          if (fwChatMessages) { const msgs = fwChatMessages.children; for (let i = msgs.length - 1; i > 0; i--) msgs[i].remove(); }
          if (fwTreeContent) fwTreeContent.innerHTML = `<div class="flex items-center gap-1.5 py-1.5 px-2 text-jm-text-muted/50 italic"><span class="text-xs">Empty — ask AI to add elements</span></div>`;
          fwElementsAdded = 0; if (fwElementCount) fwElementCount.textContent = "0 elements";
        });

        // --- Calculators ---
        function updateCalcVirtualUsers() {
          const tps = parseFloat((document.getElementById("calc-vu-tps") as HTMLInputElement)?.value || "10");
          const response = parseFloat((document.getElementById("calc-vu-response") as HTMLInputElement)?.value || "2");
          const think = parseFloat((document.getElementById("calc-vu-think") as HTMLInputElement)?.value || "3");
          const resultEl = document.getElementById("calc-vu-result"); if (resultEl) resultEl.textContent = String(Math.ceil(tps * (response + think)));
        }
        function updateCalcPacing() {
          const tph = parseFloat((document.getElementById("calc-pacing-tph") as HTMLInputElement)?.value || "36000");
          const users = parseFloat((document.getElementById("calc-pacing-users") as HTMLInputElement)?.value || "100");
          const resultEl = document.getElementById("calc-pacing-result"); if (resultEl) resultEl.textContent = ((users * 3600) / tph).toFixed(2);
        }
        function updateCalcTestData() {
          const users = parseFloat((document.getElementById("calc-data-users") as HTMLInputElement)?.value || "10");
          const duration = parseFloat((document.getElementById("calc-data-duration") as HTMLInputElement)?.value || "2");
          const testDuration = parseFloat((document.getElementById("calc-data-test-duration") as HTMLInputElement)?.value || "3");
          const resultEl = document.getElementById("calc-data-result"); if (resultEl) resultEl.textContent = String(Math.floor(users * testDuration * (60 / duration)));
        }
        function updateCalcLoadGenerator() {
          const ram = parseFloat((document.getElementById("calc-lg-ram") as HTMLInputElement)?.value || "4024");
          const first = parseFloat((document.getElementById("calc-lg-first") as HTMLInputElement)?.value || "200");
          const additional = parseFloat((document.getElementById("calc-lg-additional") as HTMLInputElement)?.value || "100");
          const os = parseFloat((document.getElementById("calc-lg-os") as HTMLInputElement)?.value || "1024");
          const resultEl = document.getElementById("calc-lg-result"); if (resultEl) resultEl.textContent = String(Math.max(0, Math.floor(((ram - os) * 0.75 - first) / additional) + 1));
        }
        function updateCalcBandwidth() {
          const users = parseFloat((document.getElementById("calc-bandwidth-users") as HTMLInputElement)?.value || "100");
          const tps = parseFloat((document.getElementById("calc-bandwidth-tps") as HTMLInputElement)?.value || "2");
          const requestSize = parseFloat((document.getElementById("calc-bandwidth-request") as HTMLInputElement)?.value || "5");
          const responseSize = parseFloat((document.getElementById("calc-bandwidth-response") as HTMLInputElement)?.value || "50");
          const overhead = parseFloat((document.getElementById("calc-bandwidth-overhead") as HTMLInputElement)?.value || "20");
          const resultEl = document.getElementById("calc-bandwidth-result");
          if (resultEl) resultEl.textContent = ((users * tps * (requestSize + responseSize) * 8 / 1024) * (1 + overhead / 100)).toFixed(2);
        }
        document.getElementById("calc-vu-tps")?.addEventListener("input", updateCalcVirtualUsers);
        document.getElementById("calc-vu-response")?.addEventListener("input", updateCalcVirtualUsers);
        document.getElementById("calc-vu-think")?.addEventListener("input", updateCalcVirtualUsers);
        document.getElementById("calc-pacing-tph")?.addEventListener("input", updateCalcPacing);
        document.getElementById("calc-pacing-users")?.addEventListener("input", updateCalcPacing);
        document.getElementById("calc-data-users")?.addEventListener("input", updateCalcTestData);
        document.getElementById("calc-data-duration")?.addEventListener("input", updateCalcTestData);
        document.getElementById("calc-data-test-duration")?.addEventListener("input", updateCalcTestData);
        document.getElementById("calc-lg-ram")?.addEventListener("input", updateCalcLoadGenerator);
        document.getElementById("calc-lg-first")?.addEventListener("input", updateCalcLoadGenerator);
        document.getElementById("calc-lg-additional")?.addEventListener("input", updateCalcLoadGenerator);
        document.getElementById("calc-lg-os")?.addEventListener("input", updateCalcLoadGenerator);
        document.getElementById("calc-bandwidth-users")?.addEventListener("input", updateCalcBandwidth);
        document.getElementById("calc-bandwidth-tps")?.addEventListener("input", updateCalcBandwidth);
        document.getElementById("calc-bandwidth-request")?.addEventListener("input", updateCalcBandwidth);
        document.getElementById("calc-bandwidth-response")?.addEventListener("input", updateCalcBandwidth);
        document.getElementById("calc-bandwidth-overhead")?.addEventListener("input", updateCalcBandwidth);

        // --- Prism Tab Switcher ---
        const prismTabs = document.querySelectorAll<HTMLButtonElement>(".prism-tab");
        prismTabs.forEach((tab) => {
          tab.addEventListener("click", () => {
            const tabId = tab.dataset.prismTab; if (!tabId) return;
            prismTabs.forEach((t) => {
              const isActive = t.dataset.prismTab === tabId;
              if (isActive) { t.classList.add("prism-tab-active", "bg-jm-tab-active", "border-t", "border-l", "border-r", "border-jm-border"); t.classList.remove("bg-transparent", "hover:bg-jm-tab-hover"); t.querySelector("span")?.classList.replace("text-jm-text-muted", "text-jm-text"); }
              else { t.classList.remove("prism-tab-active", "bg-jm-tab-active", "border-t", "border-l", "border-r", "border-jm-border"); t.classList.add("bg-transparent", "hover:bg-jm-tab-hover"); t.querySelector("span")?.classList.replace("text-jm-text", "text-jm-text-muted"); }
            });
            document.querySelectorAll(".prism-tree-content").forEach((content) => content.classList.add("hidden"));
            document.getElementById(`prism-tree-${tabId}`)?.classList.remove("hidden");
          });
        });

        // --- YouTube Facade (lazy iframe on click) ---
        document.querySelectorAll<HTMLElement>(".yt-facade").forEach((facade) => {
          facade.addEventListener("click", () => {
            const playlist = facade.dataset.playlist;
            const title = facade.dataset.title || "YouTube Playlist";
            if (!playlist) return;
            const iframe = document.createElement("iframe");
            iframe.src = `https://www.youtube.com/embed/videoseries?list=${playlist}&rel=0&modestbranding=1&autoplay=1`;
            iframe.title = title;
            iframe.allow = "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";
            iframe.allowFullscreen = true;
            iframe.style.cssText = "position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; display: block;";
            facade.innerHTML = "";
            facade.style.cursor = "default";
            facade.appendChild(iframe);
          }, { once: true });
        });

        // --- Keyboard Navigation ---
        document.addEventListener("keydown", (e) => {
          if ((e.ctrlKey || e.metaKey) && e.key === "k") {
            e.preventDefault();
            if (activeTab === "super-key") skOpenPalette();
            else { switchTab("super-key"); setTimeout(() => skOpenPalette(), 100); }
          }
          if (e.ctrlKey && e.key === "Tab") {
            e.preventDefault();
            const tabIds = Array.from(tabs).map((t) => t.dataset.tab!);
            const currentIndex = tabIds.indexOf(activeTab);
            const nextIndex = e.shiftKey ? (currentIndex - 1 + tabIds.length) % tabIds.length : (currentIndex + 1) % tabIds.length;
            switchTab(tabIds[nextIndex]);
          }
          if (e.key === "ArrowDown" || e.key === "ArrowUp") {
            const currentTree = document.querySelector(`[data-tree-product="${activeTab}"]`);
            if (!currentTree) return;
            const nodes = Array.from(currentTree.querySelectorAll<HTMLButtonElement>("[data-node]"));
            const currentNode = activeNodes[activeTab];
            const currentIndex = nodes.findIndex((n) => n.dataset.node === currentNode);
            const nextIndex = e.key === "ArrowDown" ? Math.min(currentIndex + 1, nodes.length - 1) : Math.max(currentIndex - 1, 0);
            const nextNode = nodes[nextIndex]?.dataset.node;
            if (nextNode) { activeNodes[activeTab] = nextNode; highlightTreeNode(activeTab, nextNode); showDetailContent(activeTab, nextNode); }
          }
        });
      });
    </script>
