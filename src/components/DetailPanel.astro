---
import { products, themes, jmeterElements } from "../data/products";
---

<main class="flex-1 bg-jm-bg overflow-y-auto" id="detail-panel">
  {products.map((product, pi) => (
    <div
      class:list={["product-panels", pi > 0 && "hidden"]}
      data-panels-product={product.id}
    >
      {/* Header bar mimicking JMeter's element name/section header */}
      <div class="sticky top-0 z-10 bg-jm-surface-alt/95 backdrop-blur-sm border-b border-jm-border px-6 py-2.5">
        <div class="flex items-center gap-2.5">
          <span class="text-lg">
            {product.id === "feather-wand" ? "🪄" : product.id === "super-key" ? "⌨️" : product.id === "jmeter-studio" ? "🎨" : "🚀"}
          </span>
          <h2 class="text-sm font-bold text-jm-text" style="font-family: 'Orbitron', sans-serif;" data-panel-title={product.id}>
            {product.name} <span class="text-jm-text-muted font-normal">&mdash;</span> <span class="text-jm-text-dim font-normal" data-panel-section={product.id}>Overview</span>
          </h2>
        </div>
      </div>

      {/* Panel content areas */}
      {product.treeNodes.map((node, ni) => (
        <div
          class:list={[
            "detail-content p-4 sm:p-8 panel-enter",
            ni > 0 && "hidden",
          ]}
          data-detail={`${product.id}-${node.id}`}
        >
          {/* ========== OVERVIEW PANEL ========== */}
          {node.id === "overview" && (
            <div>
              {/* Hero card */}
              <div class="overview-hero mb-6" style={`border-color: ${product.color}25;`}>
                <h3 class="product-name-gradient text-3xl sm:text-5xl leading-tight mb-3">{product.name}</h3>
                <p class="text-sm tracking-[0.15em] text-jm-text-muted uppercase mb-5" style="font-family: 'JetBrains Mono', monospace;">
                  {product.subtitlePrefix}{" "}
                  <span class="font-bold" style={`color: ${product.color}`}>{product.subtitleHighlight}</span>{" "}
                  {product.subtitleSuffix}
                </p>

                {/* Badges */}
                <div class="flex flex-wrap gap-2.5 mb-7">
                  {product.badges.map((badge) => (
                    <span
                      class:list={["badge-pill", badge.variant === "filled" ? "badge-filled" : "badge-outlined"]}
                      style={badge.variant === "filled"
                        ? `background: ${badge.color};`
                        : `border-color: ${badge.color}60; color: ${badge.color};`}
                    >
                      <span>{badge.emoji}</span>
                      {badge.label}
                    </span>
                  ))}
                </div>

                {/* Description */}
                <p class="text-base text-jm-text-dim leading-relaxed" style="font-family: 'JetBrains Mono', monospace;">{product.description}</p>
              </div>

              {/* Info cards grid */}
              <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {product.infoCards.map((card) => (
                  <div class="info-card" style={`--info-card-color: ${card.color};`}>
                    <div class="text-[11px] tracking-[0.12em] text-jm-text-muted uppercase mb-2" style="font-family: 'JetBrains Mono', monospace;">{card.label}</div>
                    <div class="text-base font-bold" style={`font-family: 'Orbitron', sans-serif; color: ${card.color};`}>
                      {card.label === "STATUS" && <span class="inline-block w-2 h-2 rounded-full mr-1.5 align-middle" style={`background: ${card.color};`} />}
                      {card.value}
                    </div>
                  </div>
                ))}
              </div>

              {/* ===== SUPER KEY SIMULATOR — Super Key only ===== */}
              {product.id === "super-key" && (
                <div class="mt-8" id="superkey-simulator">
                  {/* Hidden data store for JS */}
                  <div id="jmeter-elements-data" class="hidden" data-elements={JSON.stringify(jmeterElements)}></div>

                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-base">⌨️</span>
                    <span class="text-xs tracking-[0.15em] uppercase font-bold" style="font-family: 'JetBrains Mono', monospace; color: #ffab00;">INTERACTIVE DEMO</span>
                    <span class="flex-1 h-px ml-1" style="background: linear-gradient(to right, #ffab0040, transparent);" />
                    <button id="sk-open-palette-btn" class="text-xs px-4 py-1.5 rounded-lg border border-jm-border text-jm-text-dim hover:text-jm-text hover:border-jm-border-light hover:bg-jm-surface-alt transition-colors flex items-center gap-2" style="font-family: 'JetBrains Mono', monospace;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
                      Open Palette
                    </button>
                  </div>
                  <p class="text-sm text-jm-text-dim mb-1" style="font-family: 'JetBrains Mono', monospace;">
                    Press <kbd class="sk-kbd">Ctrl</kbd> + <kbd class="sk-kbd">K</kbd> or click the button above to open the command palette.
                  </p>
                  <p class="text-[11px] text-jm-text-muted mb-5" style="font-family: 'JetBrains Mono', monospace;">
                    Try: Thread Group → HTTP Request → View Results Tree → type "run" → type "stop"
                  </p>

                  {/* Simulator split view */}
                  <div class="flex flex-col sm:flex-row gap-4 sm:h-[420px]">
                    {/* Left: Test Plan Tree */}
                    <div class="w-full sm:w-72 sm:shrink-0 bg-jm-surface border border-jm-border rounded-xl overflow-hidden flex flex-col" style="min-height: 180px;">
                      <div class="px-3 py-2 border-b border-jm-border bg-jm-surface-alt/60 flex items-center gap-2">
                        <svg class="w-3.5 h-3.5 text-jm-amber" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                        <span class="text-[11px] font-bold text-jm-text" style="font-family: 'JetBrains Mono', monospace;">Test Plan</span>
                      </div>
                      <div class="flex-1 overflow-y-auto p-2" id="sk-tree">
                        {/* Root Test Plan node — always present */}
                        <div class="sk-tree-node flex items-center gap-1.5 px-2 py-1 rounded text-xs" data-sk-node="Test Plan" data-sk-depth="0">
                          <span class="text-sm">📋</span>
                          <span class="text-jm-text" style="font-family: 'JetBrains Mono', monospace;">Test Plan</span>
                        </div>
                        {/* Dynamic nodes inserted here by JS */}
                      </div>
                    </div>

                    {/* Right: Status / Results panel */}
                    <div class="flex-1 bg-jm-surface border border-jm-border rounded-xl overflow-hidden flex flex-col">
                      <div class="px-3 py-2 border-b border-jm-border bg-jm-surface-alt/60 flex items-center justify-between">
                        <div class="flex items-center gap-2">
                          <svg class="w-3.5 h-3.5 text-jm-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                          <span class="text-[11px] font-bold text-jm-text" style="font-family: 'JetBrains Mono', monospace;">Run Status</span>
                        </div>
                        <div class="flex items-center gap-1.5" id="sk-status-indicator">
                          <span class="w-2 h-2 rounded-full bg-jm-text-muted"></span>
                          <span class="text-[10px] text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;" id="sk-status-text">Idle</span>
                        </div>
                      </div>
                      <div class="flex-1 overflow-y-auto p-3" id="sk-results">
                        <div class="flex flex-col items-center justify-center h-full text-center opacity-60">
                          <span class="text-3xl mb-2">⌨️</span>
                          <p class="text-xs text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">Press Ctrl+K to start</p>
                          <p class="text-[10px] text-jm-text-muted mt-1" style="font-family: 'JetBrains Mono', monospace;">Add elements, then "Run" to simulate</p>
                        </div>
                      </div>
                      {/* Progress bar */}
                      <div class="h-1 bg-jm-surface-alt" id="sk-progress-bar">
                        <div class="h-full bg-jm-green transition-all duration-300" id="sk-progress" style="width: 0%;"></div>
                      </div>
                    </div>
                  </div>

                  {/* Hint footer */}
                  <div class="mt-3 flex items-center gap-4 text-[10px] text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">
                    <span><kbd class="sk-kbd text-[9px]">Ctrl+K</kbd> Command Palette</span>
                    <span><kbd class="sk-kbd text-[9px]">↑↓</kbd> Navigate</span>
                    <span><kbd class="sk-kbd text-[9px]">Enter</kbd> Select</span>
                    <span><kbd class="sk-kbd text-[9px]">Esc</kbd> Close</span>
                    <button id="sk-reset-btn" class="ml-auto text-[10px] px-3 py-1 rounded border border-jm-border text-jm-text-muted hover:text-jm-text hover:border-jm-border-light transition-colors cursor-pointer">Reset Demo</button>
                  </div>

                  {/* Disclaimer */}
                  <div class="mt-4 px-4 py-3 rounded-lg border border-jm-border bg-jm-surface-alt/30">
                    <div class="flex items-start gap-2">
                      <svg class="w-4 h-4 text-jm-amber shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
                      <div>
                        <p class="text-xs font-semibold text-jm-text mb-1" style="font-family: 'JetBrains Mono', monospace;">Interactive Simulation</p>
                        <p class="text-[11px] text-jm-text-dim leading-relaxed" style="font-family: 'JetBrains Mono', monospace;">
                          This is a browser-based demo simulating Super Key's command palette and test execution. The actual JMeter plugin features, performance, and behavior may vary. For full functionality, install the plugin in Apache JMeter.
                        </p>
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {/* ===== PRISM SIMULATOR — Prism only ===== */}
              {product.id === "prism" && (
                <div class="mt-8" id="prism-simulator">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-base">🚀</span>
                    <span class="text-xs tracking-[0.15em] uppercase font-bold" style="font-family: 'JetBrains Mono', monospace; color: #00e676;">INTERACTIVE DEMO</span>
                    <span class="flex-1 h-px ml-1" style="background: linear-gradient(to right, #00e67640, transparent);" />
                  </div>
                  <p class="text-sm text-jm-text-dim mb-1" style="font-family: 'JetBrains Mono', monospace;">
                    Click tabs to switch between test plans. Experience JMeter's multi-tab interface in action.
                  </p>
                  <p class="text-[11px] text-jm-text-muted mb-5" style="font-family: 'JetBrains Mono', monospace;">
                    Try: Click different tabs → Expand tree nodes → See how Prism manages multiple test plans
                  </p>

                  {/* Mock JMeter UI with Prism tabs */}
                  <div class="prism-jmeter-window rounded-xl overflow-hidden border border-jm-border shadow-2xl">
                    {/* Title bar */}
                    <div class="h-7 bg-jm-title-bar border-b border-jm-border flex items-center px-3 gap-2">
                      <div class="flex gap-1.5">
                        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
                        <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
                        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
                      </div>
                      <span class="text-[10px] text-jm-text-dim ml-2" style="font-family: 'JetBrains Mono', monospace;">Apache JMeter (with Prism)</span>
                    </div>

                    {/* Menu bar */}
                    <div class="h-7 bg-jm-menu-bg border-b border-jm-border flex items-center px-2 gap-1">
                      {["File", "Edit", "Search", "Run", "Options", "Tools", "Help"].map(menu => (
                        <button class="px-2 py-0.5 text-[10px] text-jm-text-dim hover:text-jm-text hover:bg-jm-surface-alt rounded transition-colors" style="font-family: 'JetBrains Mono', monospace;">
                          {menu}
                        </button>
                      ))}
                    </div>

                    {/* Toolbar */}
                    <div class="h-9 bg-jm-toolbar-bg border-b border-jm-border flex items-center px-2 gap-1">
                      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="New">
                        <svg class="w-4 h-4 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                      </button>
                      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Open">
                        <svg class="w-4 h-4 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
                      </button>
                      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Save">
                        <svg class="w-4 h-4 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
                      </button>
                      <div class="w-px h-5 bg-jm-border mx-1"></div>
                      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Run">
                        <svg class="w-4 h-4 text-jm-green" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                      </button>
                      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Stop">
                        <svg class="w-4 h-4 text-jm-red" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12"/></svg>
                      </button>
                    </div>

                    {/* Prism Tab Bar */}
                    <div class="h-8 bg-jm-surface-alt border-b border-jm-border flex items-center px-1 gap-0.5" id="prism-tab-bar">
                      <button class="prism-tab prism-tab-active flex items-center gap-2 px-3 py-1 rounded-t text-[11px] bg-jm-tab-active border-t border-l border-r border-jm-border transition-colors" data-prism-tab="tab1" style="font-family: 'JetBrains Mono', monospace;">
                        <svg class="w-3 h-3 text-jm-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                        <span class="text-jm-text">PerformanceTest.jmx</span>
                        <svg class="w-3 h-3 text-jm-text-muted hover:text-jm-text cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </button>
                      <button class="prism-tab flex items-center gap-2 px-3 py-1 rounded-t text-[11px] bg-transparent hover:bg-jm-tab-hover transition-colors" data-prism-tab="tab2" style="font-family: 'JetBrains Mono', monospace;">
                        <svg class="w-3 h-3 text-jm-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                        <span class="text-jm-text-muted">featherwand-2.0.jmx</span>
                        <svg class="w-3 h-3 text-jm-text-muted hover:text-jm-text cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </button>
                      <button class="prism-tab flex items-center gap-2 px-3 py-1 rounded-t text-[11px] bg-transparent hover:bg-jm-tab-hover transition-colors" data-prism-tab="tab3" style="font-family: 'JetBrains Mono', monospace;">
                        <svg class="w-3 h-3 text-jm-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
                        <span class="text-jm-text-muted">LoadTest-API.jmx</span>
                        <svg class="w-3 h-3 text-jm-text-muted hover:text-jm-text cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                      </button>
                      <button class="ml-auto w-6 h-6 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="New Tab">
                        <svg class="w-3.5 h-3.5 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                      </button>
                    </div>

                    {/* Content area with tree */}
                    <div class="min-h-[200px] sm:h-[380px] bg-jm-bg flex flex-col sm:flex-row">
                      {/* Tree panel */}
                      <div class="w-full sm:w-64 sm:border-r border-b sm:border-b-0 border-jm-border overflow-y-auto p-2" style="max-height:200px;">
                        <div class="sm:hidden text-[10px] text-jm-text-muted px-1 pb-1" style="font-family: 'JetBrains Mono', monospace;">Test Plan Tree</div>
                        <div id="prism-tree-tab1" class="prism-tree-content">
                          <div class="text-[11px]" style="font-family: 'JetBrains Mono', monospace;">
                            <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                              <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                              <span class="text-sm">📋</span>
                              <span class="text-jm-text">TestPlan-Tomcat-Examples</span>
                            </div>
                            <div class="ml-4">
                              <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                                <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                                <span class="text-sm">⚙️</span>
                                <span class="text-jm-cyan font-semibold">Thread Group</span>
                              </div>
                              <div class="ml-4">
                                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                  <span class="w-3"></span>
                                  <span class="text-sm">📋</span>
                                  <span class="text-jm-text-dim">HTTP Header Manager</span>
                                </div>
                                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                  <span class="w-3"></span>
                                  <span class="text-sm">📋</span>
                                  <span class="text-jm-text-dim">User Defined Variables1</span>
                                </div>
                                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                  <span class="w-3"></span>
                                  <span class="text-sm">📋</span>
                                  <span class="text-jm-text-dim">HTTP Request Defaults</span>
                                </div>
                                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                  <span class="w-3"></span>
                                  <span class="text-sm">🍪</span>
                                  <span class="text-jm-text-dim">HTTP Cookie Manager</span>
                                </div>
                                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                                  <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                                  <span class="text-sm">📦</span>
                                  <span class="text-jm-text-dim">Transaction Controller</span>
                                </div>
                                <div class="ml-4">
                                  <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                                    <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                                    <span class="text-sm">🔁</span>
                                    <span class="text-jm-text-dim">Loop Controller</span>
                                  </div>
                                  <div class="ml-4">
                                    <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                      <span class="w-3"></span>
                                      <span class="text-sm">🌐</span>
                                      <span class="text-jm-text-dim">memorySample1</span>
                                    </div>
                                    <div class="ml-4">
                                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                        <span class="w-3"></span>
                                        <span class="text-sm">🔍</span>
                                        <span class="text-jm-text-dim">textExtractor</span>
                                      </div>
                                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                        <span class="w-3"></span>
                                        <span class="text-sm">🔍</span>
                                        <span class="text-jm-text-dim">textExtractor</span>
                                      </div>
                                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                        <span class="w-3"></span>
                                        <span class="text-sm">📊</span>
                                        <span class="text-jm-text-dim">code200</span>
                                      </div>
                                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                        <span class="w-3"></span>
                                        <span class="text-sm">🔍</span>
                                        <span class="text-jm-text-dim">containsText</span>
                                      </div>
                                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                        <span class="w-3"></span>
                                        <span class="text-sm">📊</span>
                                        <span class="text-jm-text-dim">responseCode(2-3-&#123;text&#125;)</span>
                                      </div>
                                    </div>
                                    <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                                      <span class="w-3"></span>
                                      <span class="text-sm">🌐</span>
                                      <span class="text-jm-text-dim">memorySample2</span>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                        <div id="prism-tree-tab2" class="prism-tree-content hidden">
                          <div class="text-[11px]" style="font-family: 'JetBrains Mono', monospace;">
