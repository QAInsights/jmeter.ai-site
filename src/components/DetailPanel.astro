---
import { products, playlistConfig } from "../data/products";
import PromptsPanel from "./PromptsPanel.astro";
import BlogPanel from "./BlogPanel.astro";
import OverviewPanel from "./panels/OverviewPanel.astro";
import FeaturesPanel from "./panels/FeaturesPanel.astro";
import OssProPanel from "./panels/OssProPanel.astro";
import InstallationPanel from "./panels/InstallationPanel.astro";
import GithubPanel from "./panels/GithubPanel.astro";
import ConnectPanel from "./panels/ConnectPanel.astro";
import CalculatorsPanel from "./panels/CalculatorsPanel.astro";
import PlaylistPanel from "./panels/PlaylistPanel.astro";
import { productEmoji } from "./panels/constants";
---

<main class="flex-1 bg-jm-bg overflow-y-auto" id="detail-panel">
  {products.map((product, pi) => (
    <div
      class:list={["product-panels", pi > 0 && "hidden"]}
      data-panels-product={product.id}
    >
      {/* Header bar mimicking JMeter's element name/section header */}
      <div class="sticky top-0 z-10 bg-jm-surface-alt/95 backdrop-blur-sm border-b border-jm-border px-6 py-2.5">
        <div class="flex items-center gap-2.5">
          <span class="text-lg">
            {productEmoji[product.id] ?? "🚀"}
          </span>
          <h2 class="text-sm font-bold text-jm-text" style="font-family: 'Orbitron', sans-serif;" data-panel-title={product.id}>
            {product.name} <span class="text-jm-text-muted font-normal">&mdash;</span> <span class="text-jm-text-dim font-normal" data-panel-section={product.id}>Overview</span>
          </h2>
        </div>
      </div>

      {/* Panel content areas */}
      {product.treeNodes.map((node, ni) => (
        <div
          class:list={[
            (node.id === "prompts" || node.id === "blog") ? "detail-content panel-enter h-full" : "detail-content p-4 sm:p-8 panel-enter",
            ni > 0 && "hidden",
          ]}
          data-detail={`${product.id}-${node.id}`}
        >
          {node.id === "overview" && <OverviewPanel product={product} />}

          {node.id === "calculators" && product.id === "perftractor" && <CalculatorsPanel />}

          {node.id in playlistConfig && product.id === "academy" && (
            <PlaylistPanel pl={playlistConfig[node.id as keyof typeof playlistConfig]} />
          )}

          {node.id === "features" && <FeaturesPanel product={product} />}

          {node.id === "oss-pro" && <OssProPanel product={product} />}

          {node.id === "installation" && <InstallationPanel product={product} />}

          {node.id === "github" && <GithubPanel product={product} />}

          {node.id === "prompts" && <PromptsPanel />}

          {node.id === "blog" && <BlogPanel />}

          {node.id === "connect" && <ConnectPanel product={product} />}
        </div>
      ))}
    </div>
  ))}
</main>
