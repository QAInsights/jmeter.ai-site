---
import { products } from "../data/products";

const nodeIcons: Record<string, string> = {
  "info": '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  "zap": '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
  "git-compare": '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M13 6h3a2 2 0 0 1 2 2v7"/><path d="M11 18H8a2 2 0 0 1-2-2V9"/>',
  "download": '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/>',
  "github": '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
  "users": '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};

const productIcons: Record<string, string> = {
  "wand-sparkles": '<path d="m21.64 3.64-1.28-1.28a1.21 1.21 0 0 0-1.72 0L2.36 18.64a1.21 1.21 0 0 0 0 1.72l1.28 1.28a1.2 1.2 0 0 0 1.72 0L21.64 5.36a1.2 1.2 0 0 0 0-1.72"/><path d="m14 7 3 3"/><path d="M5 6v4"/><path d="M19 14v4"/><path d="M10 2v2"/><path d="M7 8H3"/><path d="M21 16h-4"/><path d="M11 3H9"/>',
  "keyboard": '<path d="M10 8h.01"/><path d="M12 12h.01"/><path d="M14 8h.01"/><path d="M16 12h.01"/><path d="M18 8h.01"/><path d="M6 8h.01"/><path d="M7 16h10"/><path d="M8 12h.01"/><rect width="20" height="16" x="2" y="4" rx="2"/>',
  "palette": '<circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>',
  "app-window": '<rect width="20" height="16" x="2" y="4" rx="2"/><path d="M10 4v4"/><path d="M2 8h20"/><path d="M6 4v4"/>',
};
---

<aside
  class="bg-jm-surface border-r border-jm-border flex flex-col select-none overflow-y-auto shrink-0 transition-all duration-300"
  id="tree-panel"
  role="tree"
  aria-label="Product navigation"
  style="width: 256px;"
>
  {products.map((product, pi) => (
    <div
      class:list={["tree-product", pi > 0 && "hidden"]}
      data-tree-product={product.id}
    >
      {/* Product root node */}
      <div class="flex items-center gap-2 px-3 py-2 border-b border-jm-border">
        <svg class="w-4 h-4 text-jm-text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m6 9 6 6 6-6"/>
        </svg>
        <svg class="w-4 h-4 shrink-0" style={`color: ${product.color}`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={productIcons[product.icon] || ""} />
        <span class="text-xs font-semibold text-jm-text truncate">{product.name}</span>
      </div>

      {/* Tree nodes */}
      <div class="tree-line ml-3">
        {product.treeNodes.map((node, ni) => (
          <button
            class:list={[
              "tree-node group flex items-center gap-2.5 w-full text-left px-4 py-2 text-xs transition-all relative",
              ni === 0
                ? "bg-jm-tree-active/60 text-jm-text"
                : "text-jm-text-dim hover:bg-jm-tree-hover hover:text-jm-text",
            ]}
            data-node={node.id}
            data-product={product.id}
            role="treeitem"
            aria-selected={ni === 0 ? "true" : "false"}
          >
            {/* Connector branch */}
            <span class="absolute left-[10px] top-1/2 w-3 h-px bg-jm-border" />
            <svg class="w-3.5 h-3.5 shrink-0 relative z-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={nodeIcons[node.icon] || ""} />
            <span class="truncate">{node.label}</span>
            {ni === 0 && (
              <span class="absolute left-0 top-0 bottom-0 w-[2px] rounded-r" style={`background: ${product.color}`} />
            )}
          </button>
        ))}
      </div>
    </div>
  ))}
</aside>
