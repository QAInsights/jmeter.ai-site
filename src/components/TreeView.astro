---
import { products } from "../data/products";

---

<aside
  class="bg-jm-surface border-r border-jm-border flex flex-col select-none overflow-y-auto shrink-0 transition-all duration-300"
  id="tree-panel"
  role="tree"
  aria-label="Product navigation"
  style="width: 256px;"
>
  {products.map((product, pi) => (
    <div
      class:list={["tree-product", pi > 0 && "hidden"]}
      data-tree-product={product.id}
    >
      {/* Product root node */}
      <div class="flex items-center gap-2 px-3 py-2 border-b border-jm-border">
        <svg class="w-4 h-4 text-jm-text-muted"><use href="#icon-chevron-down"/></svg>
        <svg class="w-4 h-4 shrink-0" style={`color: ${product.color}`}><use href={`#icon-${product.icon}`}/></svg>
        <span class="text-xs font-semibold text-jm-text truncate">{product.name}</span>
      </div>

      {/* Tree nodes */}
      <div class="tree-line ml-3">
        {product.treeNodes.map((node, ni) => (
          <button
            class:list={[
              "tree-node group flex items-center gap-2.5 w-full text-left px-4 py-2 text-xs transition-all relative",
              ni === 0
                ? "bg-jm-tree-active/60 text-jm-text"
                : "text-jm-text-dim hover:bg-jm-tree-hover hover:text-jm-text",
            ]}
            data-node={node.id}
            data-product={product.id}
            data-href={node.href ?? undefined}
            role="treeitem"
            aria-selected={ni === 0 ? "true" : "false"}
          >
            {/* Connector branch */}
            <span class="absolute left-[10px] top-1/2 w-3 h-px bg-jm-border" />
            <svg class="w-3.5 h-3.5 shrink-0 relative z-10"><use href={`#icon-${node.icon}`}/></svg>
            <span class="truncate">{node.label}</span>
            {ni === 0 && (
              <span class="absolute left-0 top-0 bottom-0 w-[2px] rounded-r" style={`background: ${product.color}`} />
            )}
          </button>
        ))}
      </div>
    </div>
  ))}
</aside>
