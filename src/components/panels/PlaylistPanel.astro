---
interface PlaylistEntry {
  emoji: string;
  label: string;
  title: string;
  highlight: string;
  description: string;
  playlistId: string;
  slug: string;
  subtitle: string;
}

interface Props {
  pl: PlaylistEntry;
}

const { pl } = Astro.props;
---

<div>
  {/* Section label */}
  <div class="flex items-center gap-2 mb-1">
    <span class="text-xs">{pl.emoji}</span>
    <span class="text-xs tracking-[0.15em] uppercase font-bold" style="font-family: 'JetBrains Mono', monospace; color: #a78bfa;">{pl.label}</span>
    <span class="flex-1 h-px ml-1" style="background: linear-gradient(to right, #a78bfa40, transparent);" />
  </div>

  {/* Heading */}
  <h3 class="text-4xl font-bold text-jm-text mb-2" style="font-family: 'Orbitron', sans-serif;">
    {pl.title} <span style="color: #a78bfa;">{pl.highlight}</span>
  </h3>
  <p class="text-base text-jm-text-dim leading-relaxed mb-8" style="font-family: 'JetBrains Mono', monospace;">
    {pl.description}
  </p>

  {/* Player shell */}
  <div class="rounded-2xl overflow-hidden" style="background: #0a0a12; border: 1px solid #a78bfa30; box-shadow: 0 0 0 1px #a78bfa10, 0 8px 64px #a78bfa22, 0 2px 12px rgba(0,0,0,0.6);">

    {/* Window chrome / title bar */}
    <div class="flex items-center justify-between px-4 py-3" style="background: linear-gradient(to right, #13111a, #0e0c18); border-bottom: 1px solid #a78bfa20;">
      <div class="flex items-center gap-3">
        {/* Traffic light dots */}
        <div class="flex items-center gap-1.5">
          <div class="w-3 h-3 rounded-full" style="background: #ff5f57;"></div>
          <div class="w-3 h-3 rounded-full" style="background: #febc2e;"></div>
          <div class="w-3 h-3 rounded-full" style="background: #28c840;"></div>
        </div>
        <div class="w-px h-4" style="background: #a78bfa20;"></div>
        {/* Path */}
        <div class="flex items-center gap-1.5">
          <svg class="w-3 h-3" style="color: #a78bfa;" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81zM9.75 15.5v-7l6.25 3.5-6.25 3.5z"/></svg>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #a78bfa;">QAInsights</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #4b5563;">/</span>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #e5e7eb;">{pl.slug}</span>
        </div>
      </div>
      {/* Playlist live badge */}
      <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full" style="background: #a78bfa15; border: 1px solid #a78bfa30;">
        <div class="w-1.5 h-1.5 rounded-full" style="background: #a78bfa; animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;"></div>
        <span style="font-family: 'JetBrains Mono', monospace; font-size: 9px; color: #a78bfa; letter-spacing: 0.12em;">PLAYLIST</span>
      </div>
    </div>

    {/* Accent line */}
    <div style="height: 2px; background: linear-gradient(to right, #a78bfa, #7c3aed, transparent);"></div>

    {/* Lazy iframe — loads on click */}
    <div
      class="yt-facade"
      data-playlist={pl.playlistId}
      data-title={`${pl.subtitle} by QAInsights`}
      style="position: relative; padding-bottom: 56.25%; height: 0; background: linear-gradient(135deg, #0f0a1e 0%, #1a1035 50%, #0a0614 100%); cursor: pointer;"
    >
      <div style="position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px;">
        <div style="display: flex; flex-direction: column; align-items: center; gap: 12px;">
          <div style="width: 72px; height: 72px; background: #ff0000; border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 32px #ff000060;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <div style="text-align: center;">
            <div style="font-family: 'Orbitron', sans-serif; font-size: 13px; color: #e5e7eb; font-weight: 600; letter-spacing: 0.05em;">{pl.subtitle}</div>
            <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #a78bfa; margin-top: 4px; letter-spacing: 0.1em;">by QAInsights</div>
          </div>
        </div>
        <div style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #ffffff60; border: 1px solid #ffffff20; padding: 4px 12px; border-radius: 4px;">▶ Click to load playlist</div>
      </div>
    </div>

    {/* Bottom info bar */}
    <div class="flex items-center justify-between px-4 py-3" style="background: linear-gradient(to right, #13111a, #0e0c18); border-top: 1px solid #a78bfa20;">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-1.5">
          <svg class="w-3 h-3" style="color: #6b7280;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 8 6 4-6 4V8z"/></svg>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #6b7280;">{pl.subtitle}</span>
        </div>
        <div class="w-1 h-1 rounded-full" style="background: #374151;"></div>
        <div class="flex items-center gap-1.5">
          <svg class="w-3 h-3" style="color: #6b7280;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #6b7280;">Updates automatically</span>
        </div>
      </div>
      <a
        href={`https://youtube.com/playlist?list=${pl.playlistId}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg transition-all hover:opacity-100 opacity-80"
        style="background: #a78bfa18; border: 1px solid #a78bfa30; color: #a78bfa; font-family: 'JetBrains Mono', monospace; font-size: 10px;"
      >
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.19a3.02 3.02 0 0 0-2.12-2.14C19.54 3.5 12 3.5 12 3.5s-7.54 0-9.38.55A3.02 3.02 0 0 0 .5 6.19C0 8.04 0 12 0 12s0 3.96.5 5.81a3.02 3.02 0 0 0 2.12 2.14C4.46 20.5 12 20.5 12 20.5s7.54 0 9.38-.55a3.02 3.02 0 0 0 2.12-2.14C24 15.96 24 12 24 12s0-3.96-.5-5.81zM9.75 15.5v-7l6.25 3.5-6.25 3.5z"/></svg>
        Open in YouTube
      </a>
    </div>
  </div>

  {/* Keyboard hint */}
  <p class="mt-3 text-center" style="font-family: 'JetBrains Mono', monospace; font-size: 10px; color: #374151;">
    Use the playlist panel inside the player to browse all videos
  </p>
</div>
