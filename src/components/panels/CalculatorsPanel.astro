---
import { calcInputClass } from "./constants";
---

<div>
  {/* Section label */}
  <div class="flex items-center gap-2 mb-1">
    <span class="text-xs">🧮</span>
    <span class="text-xs tracking-[0.15em] uppercase font-bold" style="font-family: 'JetBrains Mono', monospace; color: #ff6b6b;">PERFTRACTOR</span>
    <span class="flex-1 h-px ml-1" style="background: linear-gradient(to right, #ff6b6b40, transparent);" />
  </div>

  {/* Heading */}
  <h3 class="text-4xl font-bold text-jm-text mb-2" style="font-family: 'Orbitron', sans-serif;">
    Perftractor <span class="product-name-gradient">Calculators</span>
  </h3>
  <p class="text-base text-jm-text-dim leading-relaxed mb-8">All calculators in one convenient place for your performance testing needs.</p>

  {/* Little's Law Info */}
  <div class="mb-6 bg-jm-surface border border-jm-border rounded-lg p-5">
    <h4 class="text-lg font-bold text-jm-text mb-2" style="font-family: 'Orbitron', sans-serif;">⚖️ Little's Law</h4>
    <p class="text-sm text-jm-text-dim mb-3" style="font-family: 'JetBrains Mono', monospace;">
      Simply put, here is the formula: <strong class="text-jm-text">N = Z × (R + T)</strong> where:
    </p>
    <ul class="text-sm text-jm-text-dim space-y-1 ml-4" style="font-family: 'JetBrains Mono', monospace;">
      <li><strong class="text-jm-text">N</strong> = Number of Users</li>
      <li><strong class="text-jm-text">Z</strong> = Number of Transactions per second</li>
      <li><strong class="text-jm-text">R</strong> = Average Response Time in seconds</li>
      <li><strong class="text-jm-text">T</strong> = Think Time in seconds</li>
    </ul>
  </div>

  {/* All Calculators */}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    {/* Virtual Users Calculator */}
    <div class="bg-jm-surface border border-jm-border rounded-lg p-5">
      <h5 class="text-base font-bold text-jm-text mb-2 flex items-center gap-2" style="font-family: 'Orbitron', sans-serif;">
        <span>👥</span> Virtual Users
      </h5>
      <p class="text-xs text-jm-text-dim mb-4" style="font-family: 'JetBrains Mono', monospace;">
        Calculate the number of virtual users needed.
      </p>

      <div class="space-y-3">
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Transactions Per Second:</label>
          <input type="number" id="calc-vu-tps" value="10" min="1" max="10000" step="1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Average Response Time (seconds):</label>
          <input type="number" id="calc-vu-response" value="2" min="0.1" max="60" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Think Time (seconds):</label>
          <input type="number" id="calc-vu-think" value="3" min="0" max="300" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div class="pt-3 border-t border-jm-border">
          <p class="text-sm font-semibold" style="font-family: 'JetBrains Mono', monospace; color: #ff6b6b;">
            Result: <span id="calc-vu-result">50</span> virtual users required
          </p>
        </div>
      </div>
    </div>

    {/* Pacing Calculator */}
    <div class="bg-jm-surface border border-jm-border rounded-lg p-5">
      <h5 class="text-base font-bold text-jm-text mb-2 flex items-center gap-2" style="font-family: 'Orbitron', sans-serif;">
        <span>⌛</span> Pacing
      </h5>
      <p class="text-xs text-jm-text-dim mb-4" style="font-family: 'JetBrains Mono', monospace;">
        Calculate the time between consecutive transactions.
      </p>

      <div class="space-y-3">
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Transactions Per Hour:</label>
          <input type="number" id="calc-pacing-tph" value="36000" min="60" max="1000000" step="100" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Number of Virtual Users:</label>
          <input type="number" id="calc-pacing-users" value="100" min="1" max="10000" step="1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div class="pt-3 border-t border-jm-border">
          <p class="text-sm font-semibold" style="font-family: 'JetBrains Mono', monospace; color: #ff6b6b;">
            Result: <span id="calc-pacing-result">10.00</span> seconds pacing required
          </p>
        </div>
      </div>
    </div>

    {/* Test Data Calculator */}
    <div class="bg-jm-surface border border-jm-border rounded-lg p-5">
      <h5 class="text-base font-bold text-jm-text mb-2 flex items-center gap-2" style="font-family: 'Orbitron', sans-serif;">
        <span>🧪</span> Test Data
      </h5>
      <p class="text-xs text-jm-text-dim mb-4" style="font-family: 'JetBrains Mono', monospace;">
        Estimate unique data required for each virtual user.
      </p>

      <div class="space-y-3">
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Number of Virtual Users:</label>
          <input type="number" id="calc-data-users" value="10" min="1" max="10000" step="1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Each VUser Duration (minutes):</label>
          <input type="number" id="calc-data-duration" value="2" min="0.1" max="60" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Test Duration (hours):</label>
          <input type="number" id="calc-data-test-duration" value="3" min="0.1" max="24" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div class="pt-3 border-t border-jm-border">
          <p class="text-sm font-semibold" style="font-family: 'JetBrains Mono', monospace; color: #ff6b6b;">
            Result: <span id="calc-data-result">900</span> test data records required
          </p>
        </div>
      </div>
    </div>

    {/* Load Generator Calculator */}
    <div class="bg-jm-surface border border-jm-border rounded-lg p-5">
      <h5 class="text-base font-bold text-jm-text mb-2 flex items-center gap-2" style="font-family: 'Orbitron', sans-serif;">
        <span>🔋</span> Load Generators
      </h5>
      <p class="text-xs text-jm-text-dim mb-4" style="font-family: 'JetBrains Mono', monospace;">
        Calculate how many load generators you need.
      </p>

      <div class="space-y-3">
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Total LG RAM (MB):</label>
          <input type="number" id="calc-lg-ram" value="4024" min="1024" max="262144" step="1024" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">First VUser Memory (MB):</label>
          <input type="number" id="calc-lg-first" value="200" min="50" max="1024" step="10" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Each Additional VUser Memory (MB):</label>
          <input type="number" id="calc-lg-additional" value="100" min="10" max="1024" step="10" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">OS RAM (typically 700-750 MB):</label>
          <input type="number" id="calc-lg-os" value="1024" min="512" max="4096" step="128" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div class="pt-3 border-t border-jm-border">
          <p class="text-sm font-semibold" style="font-family: 'JetBrains Mono', monospace; color: #ff6b6b;">
            Result: <span id="calc-lg-result">23</span> virtual users per load generator
          </p>
        </div>
      </div>
    </div>

    {/* Network Bandwidth Calculator */}
    <div class="bg-jm-surface border border-jm-border rounded-lg p-5">
      <h5 class="text-base font-bold text-jm-text mb-2 flex items-center gap-2" style="font-family: 'Orbitron', sans-serif;">
        <span>🌐</span> Network Bandwidth
      </h5>
      <p class="text-xs text-jm-text-dim mb-4" style="font-family: 'JetBrains Mono', monospace;">
        Calculate required network bandwidth for your performance test.
      </p>

      <div class="space-y-3">
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Concurrent Users:</label>
          <input type="number" id="calc-bandwidth-users" value="100" min="1" max="10000" step="1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Transactions Per Second (per user):</label>
          <input type="number" id="calc-bandwidth-tps" value="2" min="0.1" max="100" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Average Request Size (KB):</label>
          <input type="number" id="calc-bandwidth-request" value="5" min="0.1" max="1024" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Average Response Size (KB):</label>
          <input type="number" id="calc-bandwidth-response" value="50" min="0.1" max="10240" step="0.1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div>
          <label class="block text-xs text-jm-text-muted mb-1" style="font-family: 'JetBrains Mono', monospace;">Protocol Overhead (%):</label>
          <input type="number" id="calc-bandwidth-overhead" value="20" min="0" max="50" step="1" class={calcInputClass} style="font-family: 'JetBrains Mono', monospace;" />
        </div>
        <div class="pt-3 border-t border-jm-border">
          <p class="text-sm font-semibold" style="font-family: 'JetBrains Mono', monospace; color: #ff6b6b;">
            Result: <span id="calc-bandwidth-result">12.00</span> Mbps required
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
