---
import type { Product } from "../../data/products";

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div>
  <h3 class="text-2xl font-bold text-jm-text mb-2" style="font-family: 'Orbitron', sans-serif;">Installation</h3>
  <p class="text-sm text-jm-text-muted mb-6">Get {product.name} up and running in minutes.</p>
  <div class="space-y-4">
    {product.installation.map((step, si) => (
      <div class="flex gap-4">
        <div class="flex flex-col items-center">
          <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold shrink-0" style={`background: ${product.color}20; color: ${product.color}; border: 1px solid ${product.color}40;`}>
            {si + 1}
          </div>
          {si < product.installation.length - 1 && (
            <div class="w-px flex-1 mt-2" style={`background: ${product.color}20;`} />
          )}
        </div>
        <div class="flex-1 pb-4">
          <h4 class="text-base font-semibold text-jm-text mb-1">{step.title}</h4>
          <p class="text-sm text-jm-text-dim mb-2">{step.description}</p>
          {step.code && (
            <pre class="jm-code text-[11px] whitespace-pre-wrap">{step.code}</pre>
          )}
        </div>
      </div>
    ))}
  </div>
</div>
