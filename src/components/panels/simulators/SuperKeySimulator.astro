---
import type { JMeterElement } from "../../../data/products";

interface Props {
  jmeterElements: JMeterElement[];
  disclaimer: string;
}

const { jmeterElements, disclaimer } = Astro.props;
---

<div class="mt-8" id="superkey-simulator">
  {/* Hidden data store for JS */}
  <div id="jmeter-elements-data" class="hidden" data-elements={JSON.stringify(jmeterElements)}></div>

  <div class="flex items-center gap-2 mb-2">
    <span class="text-base">⌨️</span>
    <span class="text-xs tracking-[0.15em] uppercase font-bold" style="font-family: 'JetBrains Mono', monospace; color: #ffab00;">INTERACTIVE DEMO</span>
    <span class="flex-1 h-px ml-1" style="background: linear-gradient(to right, #ffab0040, transparent);" />
    <button id="sk-open-palette-btn" class="text-xs px-4 py-1.5 rounded-lg border border-jm-border text-jm-text-dim hover:text-jm-text hover:border-jm-border-light hover:bg-jm-surface-alt transition-colors flex items-center gap-2" style="font-family: 'JetBrains Mono', monospace;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/></svg>
      Open Palette
    </button>
  </div>
  <p class="text-sm text-jm-text-dim mb-1" style="font-family: 'JetBrains Mono', monospace;">
    Press <kbd class="sk-kbd">Ctrl</kbd> + <kbd class="sk-kbd">K</kbd> or click the button above to open the command palette.
  </p>
  <p class="text-[11px] text-jm-text-muted mb-5" style="font-family: 'JetBrains Mono', monospace;">
    Try: Thread Group → HTTP Request → View Results Tree → type "run" → type "stop"
  </p>

  {/* Simulator split view */}
  <div class="flex flex-col sm:flex-row gap-4 sm:h-[420px]">
    {/* Left: Test Plan Tree */}
    <div class="w-full sm:w-72 sm:shrink-0 bg-jm-surface border border-jm-border rounded-xl overflow-hidden flex flex-col" style="min-height: 180px;">
      <div class="px-3 py-2 border-b border-jm-border bg-jm-surface-alt/60 flex items-center gap-2">
        <svg class="w-3.5 h-3.5 text-jm-amber" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
        <span class="text-[11px] font-bold text-jm-text" style="font-family: 'JetBrains Mono', monospace;">Test Plan</span>
      </div>
      <div class="flex-1 overflow-y-auto p-2" id="sk-tree">
        {/* Root Test Plan node — always present */}
        <div class="sk-tree-node flex items-center gap-1.5 px-2 py-1 rounded text-xs" data-sk-node="Test Plan" data-sk-depth="0">
          <span class="text-sm">📋</span>
          <span class="text-jm-text" style="font-family: 'JetBrains Mono', monospace;">Test Plan</span>
        </div>
        {/* Dynamic nodes inserted here by JS */}
      </div>
    </div>

    {/* Right: Status / Results panel */}
    <div class="flex-1 bg-jm-surface border border-jm-border rounded-xl overflow-hidden flex flex-col">
      <div class="px-3 py-2 border-b border-jm-border bg-jm-surface-alt/60 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-3.5 h-3.5 text-jm-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
          <span class="text-[11px] font-bold text-jm-text" style="font-family: 'JetBrains Mono', monospace;">Run Status</span>
        </div>
        <div class="flex items-center gap-1.5" id="sk-status-indicator">
          <span class="w-2 h-2 rounded-full bg-jm-text-muted"></span>
          <span class="text-[10px] text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;" id="sk-status-text">Idle</span>
        </div>
      </div>
      <div class="flex-1 overflow-y-auto p-3" id="sk-results">
        <div class="flex flex-col items-center justify-center h-full text-center opacity-60">
          <span class="text-3xl mb-2">⌨️</span>
          <p class="text-xs text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">Press Ctrl+K to start</p>
          <p class="text-[10px] text-jm-text-muted mt-1" style="font-family: 'JetBrains Mono', monospace;">Add elements, then "Run" to simulate</p>
        </div>
      </div>
      {/* Progress bar */}
      <div class="h-1 bg-jm-surface-alt" id="sk-progress-bar">
        <div class="h-full bg-jm-green transition-all duration-300" id="sk-progress" style="width: 0%;"></div>
      </div>
    </div>
  </div>

  {/* Hint footer */}
  <div class="mt-3 flex items-center gap-4 text-[10px] text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">
    <span><kbd class="sk-kbd text-[9px]">Ctrl+K</kbd> Command Palette</span>
    <span><kbd class="sk-kbd text-[9px]">↑↓</kbd> Navigate</span>
    <span><kbd class="sk-kbd text-[9px]">Enter</kbd> Select</span>
    <span><kbd class="sk-kbd text-[9px]">Esc</kbd> Close</span>
    <button id="sk-reset-btn" class="ml-auto text-[10px] px-3 py-1 rounded border border-jm-border text-jm-text-muted hover:text-jm-text hover:border-jm-border-light transition-colors cursor-pointer">Reset Demo</button>
  </div>

  {/* Disclaimer */}
  <div class="mt-4 px-4 py-3 rounded-lg border border-jm-border bg-jm-surface-alt/30">
    <div class="flex items-start gap-2">
      <svg class="w-4 h-4 text-jm-amber shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      <div>
        <p class="text-xs font-semibold text-jm-text mb-1" style="font-family: 'JetBrains Mono', monospace;">Interactive Simulation</p>
        <p class="text-[11px] text-jm-text-dim leading-relaxed" style="font-family: 'JetBrains Mono', monospace;">{disclaimer}</p>
      </div>
    </div>
  </div>
</div>
