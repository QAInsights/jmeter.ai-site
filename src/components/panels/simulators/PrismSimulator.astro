---
interface Props {
  disclaimer: string;
}

const { disclaimer } = Astro.props;
---

<div class="mt-8" id="prism-simulator">
  <div class="flex items-center gap-2 mb-2">
    <span class="text-base">🚀</span>
    <span class="text-xs tracking-[0.15em] uppercase font-bold" style="font-family: 'JetBrains Mono', monospace; color: #00e676;">INTERACTIVE DEMO</span>
    <span class="flex-1 h-px ml-1" style="background: linear-gradient(to right, #00e67640, transparent);" />
  </div>
  <p class="text-sm text-jm-text-dim mb-1" style="font-family: 'JetBrains Mono', monospace;">
    Click tabs to switch between test plans. Experience JMeter's multi-tab interface in action.
  </p>
  <p class="text-[11px] text-jm-text-muted mb-5" style="font-family: 'JetBrains Mono', monospace;">
    Try: Click different tabs → Expand tree nodes → See how Prism manages multiple test plans
  </p>

  {/* Mock JMeter UI with Prism tabs */}
  <div class="prism-jmeter-window rounded-xl overflow-hidden border border-jm-border shadow-2xl">
    {/* Title bar */}
    <div class="h-7 bg-jm-title-bar border-b border-jm-border flex items-center px-3 gap-2">
      <div class="flex gap-1.5">
        <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-amber-500/80"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
      </div>
      <span class="text-[10px] text-jm-text-dim ml-2" style="font-family: 'JetBrains Mono', monospace;">Apache JMeter (with Prism)</span>
    </div>

    {/* Menu bar */}
    <div class="h-7 bg-jm-menu-bg border-b border-jm-border flex items-center px-2 gap-1">
      {["File", "Edit", "Search", "Run", "Options", "Tools", "Help"].map(menu => (
        <button class="px-2 py-0.5 text-[10px] text-jm-text-dim hover:text-jm-text hover:bg-jm-surface-alt rounded transition-colors" style="font-family: 'JetBrains Mono', monospace;">
          {menu}
        </button>
      ))}
    </div>

    {/* Toolbar */}
    <div class="h-9 bg-jm-toolbar-bg border-b border-jm-border flex items-center px-2 gap-1">
      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="New">
        <svg class="w-4 h-4 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
      </button>
      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Open">
        <svg class="w-4 h-4 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
      </button>
      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Save">
        <svg class="w-4 h-4 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
      </button>
      <div class="w-px h-5 bg-jm-border mx-1"></div>
      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Run">
        <svg class="w-4 h-4 text-jm-green" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
      </button>
      <button class="w-7 h-7 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="Stop">
        <svg class="w-4 h-4 text-jm-red" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12"/></svg>
      </button>
    </div>

    {/* Prism Tab Bar */}
    <div class="h-8 bg-jm-surface-alt border-b border-jm-border flex items-center px-1 gap-0.5" id="prism-tab-bar">
      <button class="prism-tab prism-tab-active flex items-center gap-2 px-3 py-1 rounded-t text-[11px] bg-jm-tab-active border-t border-l border-r border-jm-border transition-colors" data-prism-tab="tab1" style="font-family: 'JetBrains Mono', monospace;">
        <svg class="w-3 h-3 text-jm-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
        <span class="text-jm-text">PerformanceTest.jmx</span>
        <svg class="w-3 h-3 text-jm-text-muted hover:text-jm-text cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <button class="prism-tab flex items-center gap-2 px-3 py-1 rounded-t text-[11px] bg-transparent hover:bg-jm-tab-hover transition-colors" data-prism-tab="tab2" style="font-family: 'JetBrains Mono', monospace;">
        <svg class="w-3 h-3 text-jm-cyan" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
        <span class="text-jm-text-muted">featherwand-2.0.jmx</span>
        <svg class="w-3 h-3 text-jm-text-muted hover:text-jm-text cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <button class="prism-tab flex items-center gap-2 px-3 py-1 rounded-t text-[11px] bg-transparent hover:bg-jm-tab-hover transition-colors" data-prism-tab="tab3" style="font-family: 'JetBrains Mono', monospace;">
        <svg class="w-3 h-3 text-jm-purple" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/></svg>
        <span class="text-jm-text-muted">LoadTest-API.jmx</span>
        <svg class="w-3 h-3 text-jm-text-muted hover:text-jm-text cursor-pointer" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <button class="ml-auto w-6 h-6 rounded hover:bg-jm-surface-alt transition-colors flex items-center justify-center" title="New Tab">
        <svg class="w-3.5 h-3.5 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
      </button>
    </div>

    {/* Content area with tree */}
    <div class="min-h-[200px] sm:h-[380px] bg-jm-bg flex flex-col sm:flex-row">
      {/* Tree panel */}
      <div class="w-full sm:w-64 sm:border-r border-b sm:border-b-0 border-jm-border overflow-y-auto p-2" style="max-height:200px;">
        <div class="sm:hidden text-[10px] text-jm-text-muted px-1 pb-1" style="font-family: 'JetBrains Mono', monospace;">Test Plan Tree</div>
        <div id="prism-tree-tab1" class="prism-tree-content">
          <div class="text-[11px]" style="font-family: 'JetBrains Mono', monospace;">
            <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
              <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              <span class="text-sm">📋</span>
              <span class="text-jm-text">TestPlan-Tomcat-Examples</span>
            </div>
            <div class="ml-4">
              <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                <span class="text-sm">⚙️</span>
                <span class="text-jm-cyan font-semibold">Thread Group</span>
              </div>
              <div class="ml-4">
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">📋</span>
                  <span class="text-jm-text-dim">HTTP Header Manager</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">📋</span>
                  <span class="text-jm-text-dim">User Defined Variables1</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">📋</span>
                  <span class="text-jm-text-dim">HTTP Request Defaults</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">🍪</span>
                  <span class="text-jm-text-dim">HTTP Cookie Manager</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                  <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                  <span class="text-sm">📦</span>
                  <span class="text-jm-text-dim">Transaction Controller</span>
                </div>
                <div class="ml-4">
                  <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded cursor-pointer">
                    <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                    <span class="text-sm">🔁</span>
                    <span class="text-jm-text-dim">Loop Controller</span>
                  </div>
                  <div class="ml-4">
                    <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                      <span class="w-3"></span>
                      <span class="text-sm">🌐</span>
                      <span class="text-jm-text-dim">memorySample1</span>
                    </div>
                    <div class="ml-4">
                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                        <span class="w-3"></span>
                        <span class="text-sm">🔍</span>
                        <span class="text-jm-text-dim">textExtractor</span>
                      </div>
                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                        <span class="w-3"></span>
                        <span class="text-sm">🔍</span>
                        <span class="text-jm-text-dim">textExtractor</span>
                      </div>
                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                        <span class="w-3"></span>
                        <span class="text-sm">📊</span>
                        <span class="text-jm-text-dim">code200</span>
                      </div>
                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                        <span class="w-3"></span>
                        <span class="text-sm">🔍</span>
                        <span class="text-jm-text-dim">containsText</span>
                      </div>
                      <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                        <span class="w-3"></span>
                        <span class="text-sm">📊</span>
                        <span class="text-jm-text-dim">responseCode(2-3-&#123;text&#125;)</span>
                      </div>
                    </div>
                    <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                      <span class="w-3"></span>
                      <span class="text-sm">🌐</span>
                      <span class="text-jm-text-dim">memorySample2</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div id="prism-tree-tab2" class="prism-tree-content hidden">
          <div class="text-[11px]" style="font-family: 'JetBrains Mono', monospace;">
            <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
              <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              <span class="text-sm">📋</span>
              <span class="text-jm-text">Feather Wand Test Plan</span>
            </div>
            <div class="ml-4">
              <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                <span class="text-sm">⚙️</span>
                <span class="text-jm-text">AI Generated Thread Group</span>
              </div>
              <div class="ml-4">
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">🌐</span>
                  <span class="text-jm-text-dim">HTTP Request - Login</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">🌐</span>
                  <span class="text-jm-text-dim">HTTP Request - Dashboard</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">🌳</span>
                  <span class="text-jm-text-dim">View Results Tree</span>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div id="prism-tree-tab3" class="prism-tree-content hidden">
          <div class="text-[11px]" style="font-family: 'JetBrains Mono', monospace;">
            <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
              <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
              <span class="text-sm">📋</span>
              <span class="text-jm-text">API Load Test</span>
            </div>
            <div class="ml-4">
              <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                <svg class="w-3 h-3 text-jm-text-dim" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>
                <span class="text-sm">⚙️</span>
                <span class="text-jm-text">Thread Group - 100 Users</span>
              </div>
              <div class="ml-4">
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">🌐</span>
                  <span class="text-jm-text-dim">GET /api/users</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">🌐</span>
                  <span class="text-jm-text-dim">POST /api/orders</span>
                </div>
                <div class="flex items-center gap-1 py-1 px-1 hover:bg-jm-tree-hover rounded">
                  <span class="w-3"></span>
                  <span class="text-sm">📈</span>
                  <span class="text-jm-text-dim">Summary Report</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Right panel - placeholder */}
      <div class="flex-1 flex items-center justify-center text-center p-8">
        <div>
          <span class="text-4xl mb-3 block">🚀</span>
          <p class="text-sm text-jm-text mb-1" style="font-family: 'JetBrains Mono', monospace;">Multi-Tab Interface Active</p>
          <p class="text-xs text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">Switch between tabs to see different test plans</p>
        </div>
      </div>
    </div>

    {/* Status bar */}
    <div class="h-6 bg-jm-status-bg border-t border-jm-border flex items-center px-3 text-[10px] text-jm-text-muted" style="font-family: 'JetBrains Mono', monospace;">
      <span>Ready</span>
      <span class="mx-2">•</span>
      <span>3 tabs open</span>
      <span class="mx-2">•</span>
      <span>Prism v1.0.0</span>
    </div>
  </div>

  {/* Disclaimer */}
  <div class="mt-4 px-4 py-3 rounded-lg border border-jm-border bg-jm-surface-alt/30">
    <div class="flex items-start gap-2">
      <svg class="w-4 h-4 text-jm-amber shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      <div>
        <p class="text-xs font-semibold text-jm-text mb-1" style="font-family: 'JetBrains Mono', monospace;">Interactive Simulation</p>
        <p class="text-[11px] text-jm-text-dim leading-relaxed" style="font-family: 'JetBrains Mono', monospace;">{disclaimer}</p>
      </div>
    </div>
  </div>
</div>
