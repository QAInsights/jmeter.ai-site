---
interface Props {
  seed?: string;
  class?: string;
}

const { seed = Math.random().toString(36).substring(7), class: className = '' } = Astro.props;

// Seeded random - ensure value is strictly < 1
function seededRandom(seed: string) {
  let h = 2166136261;
  for (let i = 0; i < seed.length; i++) {
    h ^= seed.charCodeAt(i);
    h += (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24);
  }
  return () => {
    h = (h * 1664525 + 1013904223) & 0xffffffff;
    return (h >>> 0) / 4294967296;
  };
}

const rand = seededRandom(seed);

// Clean CSS gradient themes - no blobs
const themes = [
  // Purple-Teal diagonal flow
  { css: 'linear-gradient(135deg, #0f0f14 0%, #1e1b4b 30%, #312e81 50%, #0e7490 70%, #0f0f14 100%)' },
  // Amber warm glow
  { css: 'linear-gradient(160deg, #1a2332 0%, #451a03 40%, #92400e 60%, #f59e0b 80%, #1a2332 100%)' },
  // Pink sunset
  { css: 'linear-gradient(180deg, #162033 0%, #4c1d3d 30%, #9d174d 60%, #fb7185 85%, #162033 100%)' },
  // Ocean blue waves
  { css: 'linear-gradient(170deg, #0c4a6e 0%, #0369a1 35%, #0ea5e9 60%, #38bdf8 85%, #0c4a6e 100%)' },
  // Lime-Violet tech
  { css: 'linear-gradient(145deg, #0f0f14 0%, #365314 25%, #4c1d95 50%, #7c3aed 75%, #0f0f14 100%)' },
  // Sunset horizon
  { css: 'linear-gradient(180deg, #2d1b4e 0%, #7c2d12 30%, #c2410c 55%, #f97316 80%, #2d1b4e 100%)' },
  // Cyan-Purple glow
  { css: 'linear-gradient(135deg, #0f0f14 0%, #083344 30%, #1e40af 60%, #7c3aed 85%, #0f0f14 100%)' },
  // Rose-Gold shimmer
  { css: 'linear-gradient(155deg, #1a1a2e 0%, #4a192c 35%, #be185d 65%, #f9a8d4 90%, #1a1a2e 100%)' },
];

const themeIndex = Math.floor(rand() * themes.length);
const theme = themes[themeIndex];
const gradientStyle = `background: ${theme.css};`;
---

<div class:list={['mesh-gradient', className]} style={gradientStyle}>
  <div class="noise" />
</div>

<style>
  .mesh-gradient {
    position: relative;
    overflow: hidden;
    border-radius: inherit;
    width: 100%;
    height: 100%;
  }

  .noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.03;
    mix-blend-mode: overlay;
    pointer-events: none;
  }
</style>
