---

<div class="flex h-full" id="prompts-panel">
  <!-- Category Sidebar -->
  <div
    class="w-56 shrink-0 border-r border-jm-border bg-jm-surface overflow-y-auto"
    id="prompts-sidebar"
    role="list"
    aria-label="Prompt categories"
  >
    <div class="px-3 py-3 border-b border-jm-border">
      <p class="text-[10px] uppercase tracking-widest text-jm-text-muted font-semibold" style="font-family: 'JetBrains Mono', monospace;">
        Categories
      </p>
    </div>
    {promptCategories.map((cat, i) => (
      <button
        class:list={[
          "prompts-cat-btn w-full flex items-center gap-2.5 px-3 py-2.5 text-left text-xs transition-colors cursor-pointer border-l-2",
          i === 0
            ? "bg-jm-tree-active border-jm-accent text-jm-text"
            : "bg-transparent border-transparent text-jm-text-muted hover:bg-jm-tree-hover hover:text-jm-text",
        ]}
        data-cat={cat.id}
        role="listitem"
        aria-selected={i === 0 ? "true" : "false"}
      >
        <svg
          class="w-3.5 h-3.5 shrink-0"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          set:html={categoryIcons[cat.icon] ?? ""}
        />
        <span class="leading-tight">{cat.label}</span>
        <span class="ml-auto text-[10px] text-jm-text-muted shrink-0">{cat.prompts.length}</span>
      </button>
    ))}
  </div>

  <!-- Prompt Cards Area -->
  <div class="flex-1 overflow-y-auto bg-jm-bg" id="prompts-cards-area">
    {promptCategories.map((cat, ci) => (
      <div
        class:list={["prompts-cat-panel px-6 py-6", ci > 0 && "hidden"]}
        data-cat-panel={cat.id}
      >
        <!-- Category header -->
        <div class="flex items-center gap-3 mb-6">
          <svg
            class="w-5 h-5 text-jm-accent shrink-0"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={categoryIcons[cat.icon] ?? ""}
          />
          <h3 class="text-base font-bold text-jm-text" style="font-family: 'Orbitron', sans-serif;">
            {cat.label}
          </h3>
          <span class="ml-auto text-xs text-jm-text-muted bg-jm-surface px-2 py-0.5 rounded-full border border-jm-border">
            {cat.prompts.length} prompt{cat.prompts.length !== 1 ? "s" : ""}
          </span>
        </div>

        <!-- Prompt cards -->
        <div class="space-y-4">
          {cat.prompts.map((prompt) => (
            <div class="prompt-card rounded-lg border border-jm-border bg-jm-surface hover:border-jm-border-light transition-colors">
              <!-- Card header -->
              <div class="flex items-center justify-between px-4 py-3 border-b border-jm-border">
                <h4 class="text-sm font-semibold text-jm-text">{prompt.title}</h4>
                <button
                  class="copy-btn flex items-center gap-1.5 text-xs text-jm-text-muted hover:text-jm-accent transition-colors px-2 py-1 rounded hover:bg-jm-surface-alt"
                  data-prompt-id={prompt.id}
                  data-prompt-body={prompt.body}
                  title="Copy prompt"
                  aria-label={`Copy prompt: ${prompt.title}`}
                >
                  <svg class="copy-icon w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <use href="#icon-copy" />
                  </svg>
                  <svg class="check-icon w-3.5 h-3.5 hidden text-jm-green" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <use href="#icon-check" />
                  </svg>
                  <span class="copy-label">Copy</span>
                </button>
              </div>
              <!-- Card body -->
              <pre class="px-4 py-3 text-xs text-jm-text-dim font-mono leading-relaxed whitespace-pre-wrap break-words overflow-x-auto" style="font-family: 'JetBrains Mono', monospace;">{prompt.body}</pre>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  function initPromptsPanel() {
    const catBtns = document.querySelectorAll<HTMLButtonElement>(".prompts-cat-btn");
    const catPanels = document.querySelectorAll<HTMLElement>("[data-cat-panel]");

    catBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetCat = btn.dataset.cat;

        catBtns.forEach((b) => {
          const isActive = b.dataset.cat === targetCat;
          b.setAttribute("aria-selected", isActive ? "true" : "false");
          if (isActive) {
            b.classList.remove("bg-transparent", "border-transparent", "text-jm-text-muted", "hover:bg-jm-tree-hover", "hover:text-jm-text");
            b.classList.add("bg-jm-tree-active", "border-jm-accent", "text-jm-text");
          } else {
            b.classList.remove("bg-jm-tree-active", "border-jm-accent", "text-jm-text");
            b.classList.add("bg-transparent", "border-transparent", "text-jm-text-muted", "hover:bg-jm-tree-hover", "hover:text-jm-text");
          }
        });

        catPanels.forEach((panel) => {
          if (panel.dataset.catPanel === targetCat) {
            panel.classList.remove("hidden");
          } else {
            panel.classList.add("hidden");
          }
        });
      });
    });

    document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const body = btn.dataset.promptBody ?? "";
        const copyIcon = btn.querySelector<SVGElement>(".copy-icon");
        const checkIcon = btn.querySelector<SVGElement>(".check-icon");
        const label = btn.querySelector<HTMLSpanElement>(".copy-label");

        try {
          await navigator.clipboard.writeText(body);
          copyIcon?.classList.add("hidden");
          checkIcon?.classList.remove("hidden");
          if (label) label.textContent = "Copied!";
          btn.classList.add("text-jm-green");
          btn.classList.remove("text-jm-text-muted", "hover:text-jm-accent");

          setTimeout(() => {
            copyIcon?.classList.remove("hidden");
            checkIcon?.classList.add("hidden");
            if (label) label.textContent = "Copy";
            btn.classList.remove("text-jm-green");
            btn.classList.add("text-jm-text-muted", "hover:text-jm-accent");
          }, 1500);
        } catch {
          if (label) label.textContent = "Failed";
          setTimeout(() => {
            if (label) label.textContent = "Copy";
          }, 1500);
        }
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initPromptsPanel);
</script>
