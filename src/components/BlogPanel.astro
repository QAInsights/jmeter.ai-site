---
const postImports = import.meta.glob('../pages/blog/**/*.mdx', { eager: true });

const posts = Object.entries(postImports)
  .filter(([path, post]: [string, any]) => post.frontmatter && !post.frontmatter?.draft)
  .map(([path, post]: [string, any]) => ({
    slug: path.replace('../pages/blog/', '').replace(/\.mdx$/, ''),
    ...post.frontmatter,
  }))
  .sort((a: any, b: any) => new Date(b.pubDate).valueOf() - new Date(a.pubDate).valueOf());
---

<div class="h-full overflow-y-auto p-4 sm:p-8">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-2xl sm:text-3xl font-bold text-jm-text mb-2">Blog</h2>
    <p class="text-jm-text-dim text-sm mb-6">Insights, tutorials, and updates from JMeter.AI</p>

    <div class="space-y-4">
      {posts.map((post: any) => (
        <a
          href={`/blog/${post.slug}/`}
          class="block bg-jm-surface border border-jm-border rounded-lg p-5 hover:border-jm-accent/50 transition-colors"
        >
          <h3 class="text-base font-semibold text-jm-text mb-1.5">{post.title}</h3>
          <p class="text-jm-text-dim text-sm mb-3">{post.description}</p>
          <div class="flex items-center gap-3 text-xs text-jm-text-muted">
            <time datetime={new Date(post.pubDate).toISOString()}>
              {new Date(post.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span>by {post.author ?? 'QAInsights'}</span>
            {post.tags?.length > 0 && (
              <div class="flex gap-1.5">
                {post.tags.map((tag: string) => (
                  <span class="px-1.5 py-0.5 bg-jm-accent/10 text-jm-accent rounded text-[10px]">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-12">
        <p class="text-jm-text-muted">No blog posts yet. Check back soon!</p>
      </div>
    )}
  </div>
</div>
