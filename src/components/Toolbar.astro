---
/**
 * Decorative toolbar mimicking JMeter's icon toolbar.
 * Icons are inline SVGs from Lucide for zero-dependency loading.
 */
const toolbarGroups = [
  [
    { icon: "file-plus", title: "New", label: "New Test Plan" },
    { icon: "folder-open", title: "Open", label: "Open Test Plan" },
    { icon: "save", title: "Save", label: "Save" },
  ],
  [
    { icon: "scissors", title: "Cut", label: "Cut" },
    { icon: "copy", title: "Copy", label: "Copy" },
    { icon: "clipboard-paste", title: "Paste", label: "Paste" },
  ],
  [
    { icon: "play", title: "Start", label: "Start Test", accent: true },
    { icon: "square", title: "Stop", label: "Stop Test" },
    { icon: "rotate-ccw", title: "Clear", label: "Clear All" },
  ],
  [
    { icon: "toggle-left", title: "Toggle", label: "Enable/Disable" },
    { icon: "search", title: "Search", label: "Search" },
    { icon: "eraser", title: "Reset", label: "Reset Search" },
  ],
  [
    { icon: "zoom-in", title: "Zoom In", label: "Zoom In" },
    { icon: "zoom-out", title: "Zoom Out", label: "Zoom Out" },
    { icon: "refresh-cw", title: "Reset", label: "Reset All" },
    { icon: "zoom-reset", title: "Reset Zoom", label: "Reset Zoom (100%)" },
  ],
];

const iconPaths: Record<string, string> = {
  "file-plus": '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M9 15h6"/><path d="M12 18v-6"/>',
  "folder-open": '<path d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"/>',
  "save": '<path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/>',
  "scissors": '<circle cx="6" cy="6" r="3"/><path d="M8.12 8.12 12 12"/><path d="M20 4 8.12 15.88"/><circle cx="6" cy="18" r="3"/><path d="M14.8 14.8 20 20"/>',
  "copy": '<rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>',
  "clipboard-paste": '<path d="M15 2H9a1 1 0 0 0-1 1v2c0 .6.4 1 1 1h6c.6 0 1-.4 1-1V3c0-.6-.4-1-1-1Z"/><path d="M8 4H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2M16 4h2a2 2 0 0 1 2 2v2"/><path d="M21 14H11"/><path d="m15 10-4 4 4 4"/>',
  "play": '<polygon points="6 3 20 12 6 21 6 3"/>',
  "square": '<rect width="18" height="18" x="3" y="3" rx="2"/>',
  "rotate-ccw": '<path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/>',
  "toggle-left": '<rect width="20" height="12" x="2" y="6" rx="6" ry="6"/><circle cx="8" cy="12" r="2"/>',
  "search": '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>',
  "eraser": '<path d="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0l5.6 5.6c1 1 1 2.5 0 3.4L13 21"/><path d="M22 21H7"/><path d="m5 11 9 9"/>',
  "zoom-in": '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M11 8v6"/><path d="M8 11h6"/>',
  "zoom-out": '<circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/><path d="M8 11h6"/>',
  "refresh-cw": '<path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/><path d="M20 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>',
};
---

<div class="flex items-center bg-jm-toolbar-bg border-b border-jm-border px-2 py-1 gap-1 select-none shrink-0 overflow-x-auto" role="toolbar" aria-label="Toolbar">
  {toolbarGroups.map((group, gi) => (
    <div class="flex items-center gap-0.5">
      {group.map((btn) => (
        <button
          class:list={[
            "p-1.5 rounded transition-colors",
            btn.accent
              ? "text-jm-green hover:bg-jm-green/10 hover:text-jm-green"
              : "text-jm-text-muted hover:bg-jm-surface-alt hover:text-jm-text-dim",
          ]}
          title={btn.label}
          aria-label={btn.label}
          data-action={btn.icon === "zoom-in" ? "zoom-in" : btn.icon === "zoom-out" ? "zoom-out" : btn.icon === "zoom-reset" ? "zoom-reset" : btn.icon === "refresh-cw" ? "reset-all" : undefined}
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconPaths[btn.icon] || ""} />
        </button>
      ))}
      {gi < toolbarGroups.length - 1 && (
        <div class="w-px h-5 bg-jm-border mx-1.5" />
      )}
    </div>
  ))}
</div>

<script>
  const STEP = 0.1;
  const MIN = 0.5;
  const MAX = 2.0;
  const STORAGE_KEY = "jm-zoom";

  const detailPanel = document.querySelector<HTMLElement>("#detail-panel");

  function applyZoom(level: number) {
    if (!detailPanel) return;
    detailPanel.style.zoom = String(level);
    localStorage.setItem(STORAGE_KEY, String(level));
  }

  function getZoom(): number {
    return parseFloat(localStorage.getItem(STORAGE_KEY) ?? "1");
  }

  applyZoom(getZoom());

  document.querySelectorAll<HTMLButtonElement>("[data-action='zoom-in']").forEach((btn) => {
    btn.addEventListener("click", () => {
      applyZoom(Math.min(MAX, Math.round((getZoom() + STEP) * 10) / 10));
    });
  });

  document.querySelectorAll<HTMLButtonElement>("[data-action='zoom-out']").forEach((btn) => {
    btn.addEventListener("click", () => {
      applyZoom(Math.max(MIN, Math.round((getZoom() - STEP) * 10) / 10));
    });
  });

  // Zoom reset functionality
  document.querySelectorAll<HTMLButtonElement>("[data-action='zoom-reset']").forEach((btn) => {
    btn.addEventListener("click", () => {
      applyZoom(1.0);
    });
  });

  // Reset all functionality
  document.querySelectorAll<HTMLButtonElement>("[data-action='reset-all']").forEach((btn) => {
    btn.addEventListener("click", () => {
      // Reset zoom to 100%
      applyZoom(1.0);
      
      // Clear localStorage
      localStorage.clear();
      
      // Reset any form inputs
      document.querySelectorAll('input').forEach(input => {
        if (input.type === 'number') {
          // Reset to default values if available
          const defaultValue = input.getAttribute('value');
          if (defaultValue) {
            input.value = defaultValue;
          }
        } else if (input.type === 'text' || input.type === 'search') {
          input.value = '';
        }
      });
      
      // Trigger change events to update calculators
      document.querySelectorAll('input').forEach(input => {
        input.dispatchEvent(new Event('input'));
      });
    });
  });
</script>
