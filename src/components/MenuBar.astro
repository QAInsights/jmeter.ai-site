---
import { siteConfig } from "../data/products";
---

<nav class="flex items-center justify-between bg-jm-menu-bg border-b border-jm-border px-2 py-0 select-none shrink-0" role="menubar">
  <div class="flex items-center overflow-x-auto">
    {siteConfig.menuItems.map((item) => (
      <button
        class="px-3 py-1.5 text-jm-text-dim hover:text-jm-text hover:bg-jm-surface-alt rounded transition-colors cursor-default"
        style="font-family: 'JetBrains Mono', monospace; font-size: 11px;"
        role="menuitem"
      >
        {item}
      </button>
    ))}
  </div>
  
  {/* Donate button */}
  <a
    href="https://buymeacoffee.com/qainsights"
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-1.5 px-3 py-1.5 rounded transition-all hover:opacity-100 opacity-80"
    style="background: #ff6b4a15; border: 1px solid #ff6b4a30; color: #ff6b4a; font-family: 'JetBrains Mono', monospace; font-size: 10px;"
    title="Support QAInsights on Buy Me a Coffee"
  >
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.593c-5.63-5.539-11-10.297-11-14.402C1 3.518 2.318 2 5.5 2c1.881 0 3.312.803 4.5 2.338C11.188 2.803 12.619 2 14.5 2 17.682 2 19 3.518 19 7.191c0 4.105-5.37 8.863-7 10.402z"/></svg>
    Donate
  </a>
</nav>
