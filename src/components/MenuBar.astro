---
import { siteConfig } from "../data/products";
---

<nav class="flex items-center justify-between bg-jm-menu-bg border-b border-jm-border px-2 py-0 select-none shrink-0" role="menubar">
  <div class="flex items-center overflow-x-auto">
    {siteConfig.menuItems.map((item) => (
      <button
        class="px-3 py-1.5 text-jm-text-dim hover:text-jm-text hover:bg-jm-surface-alt rounded transition-colors cursor-default"
        style="font-family: 'JetBrains Mono', monospace; font-size: 11px;"
        role="menuitem"
      >
        {item}
      </button>
    ))}
  </div>
  
  {/* Donate button */}
  <a
    href="https://buymeacoffee.com/qainsights"
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-1.5 px-3 py-1.5 rounded transition-all hover:opacity-100 opacity-80"
    style="background: #ff6b4a15; border: 1px solid #ff6b4a30; color: #ff6b4a; font-family: 'JetBrains Mono', monospace; font-size: 10px;"
    title="Support QAInsights on Buy Me a Coffee"
  >
    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
      <path d="M20.88 7.56c-.05-.45-.15-.93-.3-1.36-.19-.54-.45-1.06-.77-1.53-.31-.45-.69-.86-1.12-1.2-.42-.34-.9-.62-1.41-.82-.51-.2-1.05-.32-1.6-.36-.55-.04-1.11-.01-1.66.09-.55.1-1.08.28-1.57.53-.49.25-.94.57-1.33.94-.39.37-.72.8-.98 1.27-.26.47-.45.98-.56 1.51-.11.53-.13 1.07-.06 1.61.07.54.23 1.06.47 1.54.24.48.56.92.95 1.29.39.37.84.67 1.33.89.49.22 1.02.35 1.56.39.54.04 1.09-.01 1.61-.14.52-.13 1.01-.35 1.45-.65.44-.3.82-.68 1.13-1.11.31-.43.54-.91.68-1.42.14-.51.19-1.04.14-1.58-.05-.54-.19-1.06-.42-1.54-.23-.48-.54-.92-.93-1.29-.39-.37-.84-.67-1.33-.89-.49-.22-1.02-.35-1.56-.39-.54-.04-1.09.01-1.61.14-.52.13-1.01.35-1.45.65-.44.3-.82.68-1.13 1.11-.31.43-.54.91-.68 1.42-.14.51-.19 1.04-.14 1.58z"/>
